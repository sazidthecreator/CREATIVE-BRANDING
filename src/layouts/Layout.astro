---
import '../styles/global.css';
import Navbar from '../components/Navbar.tsx';

export interface Props {
  title: string;
  description?: string;
  page?: string;
}

const {
  title,
  description = 'Sazid Hossain — Philosophy-trained Creative Technologist from Dhaka. Building AI-native digital systems, automated business funnels, and bilingual web experiences.',
  page = ''
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="color-scheme" content="dark light" />
  <meta name="theme-color" content="#030310" />
  <meta name="theme-color" content="#f7f5ff" media="(prefers-color-scheme: light)" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="/CREATIVE-BRANDING/og-image.png" />
  <script is:inline>
    (function(){
      var t = localStorage.getItem('nexus_theme') || 'dark';
      var l = localStorage.getItem('nexus_lang') || 'en';
      document.documentElement.setAttribute('data-theme', t);
      document.documentElement.setAttribute('data-lang', l);
    })();
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin="anonymous" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700;800&family=Fraunces:ital,wght@0,400;0,600;0,700;1,400;1,600&family=JetBrains+Mono:wght@400;500;600;700&family=Noto+Serif+Bengali:wght@400;600;700&display=optional" rel="stylesheet" />
  <noscript><style>.reveal { opacity: 1 !important; transform: none !important; }</style></noscript>
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to content</a>
  <!-- Cursor -->
  <div id="scrollBar"></div>
  <div id="cursor"></div>
  <div id="cursorRing"></div>

  <!-- Navigation -->
  <Navbar activePage={page} client:load />

  <!-- Main Content -->
  <main id="main-content" class="page-enter" style="padding-top: 62px;">
    <slot />
  </main>

  <!-- Footer -->
  <footer style="
    background: var(--bg2);
    border-top: 1px solid var(--border);
    padding: clamp(40px,8vw,80px) clamp(20px,5vw,80px) 40px;
    margin-top: 120px;
  ">
    <div style="max-width: 1200px; margin: 0 auto;">
      <div style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 60px; margin-bottom: 60px;"
           class="footer-grid">
        <div>
          <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 16px;">
            <div style="width:7px;height:7px;border-radius:50%;background:var(--accent);"></div>
            <span style="font-family:var(--font-display);font-weight:800;font-size:11px;letter-spacing:0.2em;text-transform:uppercase;">Sazid Hossain</span>
          </div>
          <p style="font-size: var(--text-sm); color: var(--muted2); max-width: 280px; line-height: 1.8;">
            Creative Technologist &amp; AI Automation Strategist from Dhaka. Philosophy meets technology.
          </p>
          <p style="font-family:var(--font-bn);font-size:var(--text-sm);color:var(--muted);margin-top:8px;">
            সাজিদ হোসেন — ঢাকা, বাংলাদেশ
          </p>
          <div style="display:flex;gap:10px;margin-top:20px;">
            <a href="mailto:contact@sazid.dev" class="footer-link" aria-label="Email Sazid Hossain">Email</a>
            <span style="color:var(--border2);">·</span>
            <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="footer-link" aria-label="LinkedIn profile">LinkedIn</a>
            <span style="color:var(--border2);">·</span>
            <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="footer-link" aria-label="GitHub profile">GitHub</a>
          </div>
        </div>
        <div>
          <p style="font-size:var(--text-xs);letter-spacing:0.15em;text-transform:uppercase;color:var(--muted);font-family:var(--font-mono);margin-bottom:16px;">Navigation</p>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:10px;">
            {[['/', 'Home'], ['/about', 'About'], ['/portfolio', 'Portfolio'], ['/services', 'Services']].map(([href, label]) => (
              <li><a href={href} class="footer-link">{label}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <p style="font-size:var(--text-xs);letter-spacing:0.15em;text-transform:uppercase;color:var(--muted);font-family:var(--font-mono);margin-bottom:16px;">More</p>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:10px;">
            {[['/blog', 'Blog'], ['/resume', 'Resume'], ['/philosophy', 'Philosophy'], ['/contact', 'Contact']].map(([href, label]) => (
              <li><a href={href} class="footer-link">{label}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <p style="font-size:var(--text-xs);letter-spacing:0.15em;text-transform:uppercase;color:var(--muted);font-family:var(--font-mono);margin-bottom:16px;">Status</p>
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
            <div style="width:6px;height:6px;border-radius:50%;background:#22c55e;animation:dotPulse 2.5s infinite;"></div>
            <span style="font-size:var(--text-xs);color:var(--muted2);">Available for work</span>
          </div>
          <p style="font-size:var(--text-xs);color:var(--muted);margin-bottom:4px;">Dhaka, Bangladesh</p>
          <p style="font-size:var(--text-xs);color:var(--muted);">GMT+6</p>
        </div>
      </div>
      <div style="border-top:1px solid var(--border);padding-top:24px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;">
        <p style="font-size:var(--text-xs);color:var(--muted);">© {new Date().getFullYear()} Sazid Hossain. Built with Astro + React + Tailwind.</p>
        <p style="font-size:var(--text-xs);color:var(--muted);font-family:var(--font-mono);">v2.0 — Enhanced Edition</p>
      </div>
    </div>
  </footer>

  <script>
    // Cursor (desktop pointers only)
    const cursor = document.getElementById('cursor');
    const cursorRing = document.getElementById('cursorRing');
    const supportsFinePointer = window.matchMedia('(pointer: fine)').matches;
    let mouseX = 0, mouseY = 0, ringX = 0, ringY = 0;
    if (supportsFinePointer) {
      document.addEventListener('mousemove', (e) => {
        mouseX = e.clientX; mouseY = e.clientY;
        if (cursor) { cursor.style.left = mouseX - 4.5 + 'px'; cursor.style.top = mouseY - 4.5 + 'px'; }
      });
      function animateRing() {
        ringX += (mouseX - ringX) * 0.12;
        ringY += (mouseY - ringY) * 0.12;
        if (cursorRing) { cursorRing.style.left = ringX - 16 + 'px'; cursorRing.style.top = ringY - 16 + 'px'; }
        requestAnimationFrame(animateRing);
      }
      animateRing();
      document.querySelectorAll('a,button,[role="button"]').forEach(el => {
        el.addEventListener('mouseenter', () => {
          if(cursor) cursor.style.transform='scale(2.5)';
          if(cursorRing) { cursorRing.style.width='48px'; cursorRing.style.height='48px'; }
        });
        el.addEventListener('mouseleave', () => {
          if(cursor) cursor.style.transform='scale(1)';
          if(cursorRing) { cursorRing.style.width='32px'; cursorRing.style.height='32px'; }
        });
      });
    } else {
      if (cursor) cursor.style.display = 'none';
      if (cursorRing) cursorRing.style.display = 'none';
    }

    // Scroll progress
    const scrollBar = document.getElementById('scrollBar');
    window.addEventListener('scroll', () => {
      const scrollable = document.body.scrollHeight - window.innerHeight;
      const pct = scrollable > 0 ? (window.scrollY / scrollable) * 100 : 0;
      if (scrollBar) scrollBar.style.width = pct + '%';
    });

    // Reveal on scroll
    const reveals = document.querySelectorAll('.reveal');
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => { if(e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }});
    }, { threshold: 0.1 });
    reveals.forEach(el => obs.observe(el));
  </script>

  <style>
    @media (max-width: 768px) {
      .footer-grid { grid-template-columns: 1fr 1fr !important; gap: 32px !important; }
    }
    @media (max-width: 480px) {
      .footer-grid { grid-template-columns: 1fr !important; }
    }
    .footer-link {
      font-size: var(--text-sm);
      color: var(--muted2);
      text-decoration: none;
      transition: color 0.2s;
    }
    .footer-link:hover {
      color: var(--accent);
    }
  </style>
</body>
</html>
