---
import Layout from '../layouts/Layout.astro';
import ProjectShowcase from '../components/ProjectShowcase.tsx';
import projectData from '../../data/projects.json';
---

<Layout title="Portfolio • Sazid Hossain — Creative Work & Projects" page="/portfolio">
  <!-- Hero Section -->
  <section style="
    padding: clamp(80px,12vw,140px) clamp(20px,5vw,80px);
    background: linear-gradient(180deg, var(--bg) 0%, var(--bg2) 100%);
    position: relative;
    overflow: hidden;
  ">
    <!-- Animated Background Elements -->
    <div style="
      position: absolute;
      top: -100px;
      right: -100px;
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(180,255,87,0.1) 0%, transparent 70%);
      border-radius: 50%;
      animation: float 6s ease-in-out infinite;
    "></div>
    <div style="
      position: absolute;
      bottom: -50px;
      left: -50px;
      width: 200px;
      height: 200px;
      background: radial-gradient(circle, rgba(132,94,247,0.1) 0%, transparent 70%);
      border-radius: 50%;
      animation: float 8s ease-in-out infinite reverse;
    "></div>

    <div style="max-width:1200px;margin:0 auto;position:relative;z-index:1;">
      <p class="section-label">Portfolio</p>
      <h1 style="
        font-family:var(--font-display);font-weight:800;
        font-size:clamp(2rem,6vw,4rem);line-height:1.05;
        margin-bottom:24px;color:var(--text);
      ">
        Creative Work<br/>
        <span class="gradient-text">& Digital Solutions</span>
      </h1>
      <p style="font-size:clamp(1rem,2vw,1.125rem);color:var(--text2);max-width:600px;line-height:1.8;margin-bottom:12px;">
        A curated collection of digital products, brand identities, and innovative solutions crafted for diverse industries and global clients.
      </p>
      <p style="font-family:var(--font-bn);font-size:var(--text-base);color:var(--muted);margin-bottom:0;">
        বিভিন্ন শিল্প ও আন্তর্জাতিক ক্লায়েন্টদের জন্য নির্মিত ডিজিটাল পণ্য, ব্র্যান্ড আইডেন্টিটি এবং উদ্ভাবনী সমাধান।
      </p>

      <!-- Stats -->
      <div style="
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 32px;
        margin-top: 48px;
      ">
        <div>
          <p style="font-size:var(--text-2xl);font-weight:700;color:var(--accent);margin-bottom:4px;">
            {projectData.length}+
          </p>
          <p style="font-size:var(--text-sm);color:var(--text2);">
            Projects
          </p>
        </div>
        <div>
          <p style="font-size:var(--text-2xl);font-weight:700;color:var(--accent);margin-bottom:4px;">
            5+
          </p>
          <p style="font-size:var(--text-sm);color:var(--text2);">
            Categories
          </p>
        </div>
        <div>
          <p style="font-size:var(--text-2xl);font-weight:700;color:var(--accent);margin-bottom:4px;">
            200+
          </p>
          <p style="font-size:var(--text-sm);color:var(--text2);">
            Happy Clients
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects Showcase -->
  <section style="
    padding: clamp(60px,10vw,100px) clamp(20px,5vw,80px);
    background: linear-gradient(180deg, var(--bg2) 0%, var(--bg) 100%);
  ">
    <div style="max-width:1200px;margin:0 auto;">
      <ProjectShowcase 
        client:load
        projects={projectData}
        onProjectClick={(project: any) => {
          console.log('Project clicked:', project);
        }}
      />
    </div>
  </section>

  <!-- Services Highlight -->
  <section style="
    padding: clamp(60px,10vw,100px) clamp(20px,5vw,80px);
    background: linear-gradient(180deg, var(--bg) 0%, var(--bg2) 100%);
  ">
    <div style="max-width:1200px;margin:0 auto;">
      <h2 style="
        font-family:var(--font-display);
        font-size:clamp(1.5rem,4vw,2.5rem);
        font-weight:700;
        margin-bottom:48px;
        text-align:center;
        color:var(--text);
      ">
        Services & Expertise
      </h2>

      <div style="
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 24px;
      ">
        {[
          {
            icon: '🎨',
            title: 'Brand Identity',
            desc: 'Logo design, brand guidelines, visual systems, and creative direction for lasting impact.',
            tags: ['Logo Design', 'Brand Guidelines', 'Color Theory'],
          },
          {
            icon: '🖥️',
            title: 'UI/UX Design',
            desc: 'User-centered digital experiences, wireframes, prototypes, and design systems.',
            tags: ['User Research', 'Prototyping', 'Design Systems'],
          },
          {
            icon: '⚛️',
            title: 'Web Development',
            desc: 'React, Astro, TailwindCSS — modern, performant, and scalable web applications.',
            tags: ['React', 'Astro', 'TailwindCSS'],
          },
          {
            icon: '🤖',
            title: 'AI Integration',
            desc: 'OpenAI APIs, automation workflows, intelligent systems, and modern tech stacks.',
            tags: ['AI/ML', 'n8n', 'Automation'],
          },
          {
            icon: '📱',
            title: 'Responsive Design',
            desc: 'Mobile-first approach ensuring beautiful interfaces across all devices and platforms.',
            tags: ['Mobile Design', 'Responsive', 'Accessibility'],
          },
          {
            icon: '🚀',
            title: 'Product Strategy',
            desc: 'From concept to launch — full-cycle product development and go-to-market strategies.',
            tags: ['Strategy', 'Product Design', 'Analytics'],
          },
        ].map((service) => (
          <div class="service-card">
            <div style="font-size: 48px; margin-bottom: 16px;">
              {service.icon}
            </div>
            <h3 style="
              font-family:var(--font-display);
              font-size:var(--text-lg);
              font-weight:700;
              margin-bottom:12px;
              color:var(--text);
            ">
              {service.title}
            </h3>
            <p style="
              font-size:var(--text-sm);
              color:var(--text2);
              line-height:1.6;
              margin-bottom:16px;
            ">
              {service.desc}
            </p>
            <div style="display: flex; flex-wrap: wrap; gap: 6px;">
              {service.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section style="
    padding: clamp(60px,10vw,100px) clamp(20px,5vw,80px);
    background: linear-gradient(135deg, var(--surface) 0%, var(--surface2) 100%);
  ">
    <div style="
      max-width:900px;
      margin:0 auto;
      text-align:center;
      padding: clamp(40px, 8vw, 80px);
    ">
      <h2 style="
        font-family:var(--font-display);
        font-size:clamp(1.5rem,4vw,2.5rem);
        font-weight:700;
        margin-bottom:24px;
        color:var(--text);
      ">
        Ready to Start Your<br/>
        <span class="gradient-text">Next Project?</span>
      </h2>
      <p style="
        font-size:clamp(1rem,2vw,1.125rem);
        color:var(--text2);
        margin-bottom:32px;
        line-height:1.8;
      ">
        Let's collaborate and bring your vision to life with cutting-edge design and technology.
      </p>
      <a href="/contact" class="btn btn-primary">
        Start Collaboration →
      </a>
    </div>
  </section>

  <style>
    @keyframes float {
      0%, 100% {
        transform: translateY(0px);
      }
      50% {
        transform: translateY(-20px);
      }
    }

    .service-card {
      padding: 32px;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: var(--surface);
      transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
      cursor: pointer;
    }
    .service-card:hover {
      border-color: var(--accent);
      box-shadow: 0 20px 60px rgba(180,255,87,0.15);
      transform: translateY(-8px);
    }
  </style>
</Layout>
