---
import Layout from '../layouts/Layout.astro';
import ProjectShowcase from '../components/ProjectShowcase.tsx';

const projectData = await import('../../data/projects.json').then(m => m.default);
---

<Layout title="Gallery • Sazid Hossain — Creative Work & Projects" page="/gallery">
  <!-- Hero Section -->
  <section class="gallery-hero reveal">
    <!-- Animated Background Elements -->
    <div class="gallery-glow gallery-glow-1"></div>
    <div class="gallery-glow gallery-glow-2"></div>

    <div style="max-width:1200px;margin:0 auto;position:relative;z-index:1;">
      <p class="section-label">Gallery</p>
      <h1 style="
        font-family:var(--font-display);font-weight:800;
        font-size:var(--text-4xl);line-height:1.05;
        letter-spacing:-0.02em;
        margin-bottom:24px;color:var(--text);
      ">
        Creative Work<br/>
        <span class="gradient-text">&amp; Digital Solutions</span>
      </h1>
      <p style="font-size:var(--text-lg);color:var(--text2);max-width:600px;line-height:1.8;margin-bottom:12px;">
        A curated collection of digital products, brand identities, and innovative solutions crafted for diverse industries and global clients.
      </p>
      <p style="font-family:var(--font-bn);font-size:var(--text-base);color:var(--muted);margin-bottom:0;">
        বিভিন্ন শিল্প ও আন্তর্জাতিক ক্লায়েন্টদের জন্য নির্মিত ডিজিটাল পণ্য, ব্র্যান্ড আইডেন্টিটি এবং উদ্ভাবনী সমাধান।
      </p>

      <!-- Stats -->
      <div class="gallery-stats">
        <div class="stat-item">
          <p class="stat-num">{projectData.length}+</p>
          <p class="stat-label">Projects</p>
        </div>
        <div class="stat-item">
          <p class="stat-num">5+</p>
          <p class="stat-label">Categories</p>
        </div>
        <div class="stat-item">
          <p class="stat-num">200+</p>
          <p class="stat-label">Happy Clients</p>
        </div>
        <div class="stat-item">
          <p class="stat-num">3+</p>
          <p class="stat-label">Years Active</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects Showcase -->
  <section class="gallery-showcase">
    <div style="max-width:1200px;margin:0 auto;">
      <ProjectShowcase 
        client:load
        projects={projectData}
        defaultView="masonry"
      />
    </div>
  </section>

  <!-- Services Highlight -->
  <section class="gallery-services reveal">
    <div style="max-width:1200px;margin:0 auto;">
      <p class="section-label">Capabilities</p>
      <h2 style="
        font-family:var(--font-display);
        font-size:var(--text-3xl);
        font-weight:800;
        letter-spacing:-0.02em;
        margin-bottom:clamp(32px,5vw,56px);
        color:var(--text);
      ">
        Services &amp; <span class="gradient-text">Expertise</span>
      </h2>

      <div class="services-bento">
        {[
          {
            icon: '🎨',
            title: 'Brand Identity',
            desc: 'Logo design, brand guidelines, visual systems, and creative direction for lasting impact.',
            tags: ['Logo Design', 'Brand Guidelines', 'Color Theory'],
            span: 'wide',
          },
          {
            icon: '🖥️',
            title: 'UI/UX Design',
            desc: 'User-centered digital experiences, wireframes, prototypes, and design systems.',
            tags: ['User Research', 'Prototyping', 'Design Systems'],
            span: 'normal',
          },
          {
            icon: '⚛️',
            title: 'Web Development',
            desc: 'React, Astro, TailwindCSS — modern, performant, and scalable web applications.',
            tags: ['React', 'Astro', 'TailwindCSS'],
            span: 'normal',
          },
          {
            icon: '🤖',
            title: 'AI Integration',
            desc: 'OpenAI APIs, automation workflows, intelligent systems, and modern tech stacks.',
            tags: ['AI/ML', 'n8n', 'Automation'],
            span: 'wide',
          },
          {
            icon: '📱',
            title: 'Responsive Design',
            desc: 'Mobile-first approach ensuring beautiful interfaces across all devices and platforms.',
            tags: ['Mobile Design', 'Responsive', 'Accessibility'],
            span: 'normal',
          },
          {
            icon: '🚀',
            title: 'Product Strategy',
            desc: 'From concept to launch — full-cycle product development and go-to-market strategies.',
            tags: ['Strategy', 'Product Design', 'Analytics'],
            span: 'normal',
          },
        ].map((service) => (
          <div class={`service-card card${service.span === 'wide' ? ' service-wide' : ''}`}>
            <div class="service-icon">{service.icon}</div>
            <h3 style="font-family:var(--font-display);font-size:var(--text-lg);font-weight:700;margin-bottom:10px;color:var(--text);">
              {service.title}
            </h3>
            <p style="font-size:var(--text-sm);color:var(--text2);line-height:1.7;margin-bottom:16px;">
              {service.desc}
            </p>
            <div style="display:flex;flex-wrap:wrap;gap:6px;">
              {service.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="gallery-cta reveal">
    <div class="card cta-inner">
      <div style="position:relative;z-index:1;">
        <p class="section-label" style="justify-content:center;">Next Step</p>
        <h2 style="
          font-family:var(--font-display);
          font-size:var(--text-3xl);
          font-weight:800;
          letter-spacing:-0.02em;
          margin-bottom:20px;
          color:var(--text);
        ">
          Ready to Start Your<br/>
          <span class="gradient-text">Next Project?</span>
        </h2>
        <p style="font-size:var(--text-lg);color:var(--text2);margin-bottom:8px;line-height:1.8;max-width:560px;margin-inline:auto;">
          Let's collaborate and bring your vision to life with cutting-edge design and technology.
        </p>
        <p style="font-family:var(--font-bn);font-size:var(--text-base);color:var(--muted);margin-bottom:36px;">
          আপনার স্বপ্নের প্রজেক্ট তৈরি করতে আমার সাথে যোগ দিন।
        </p>
        <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
          <a href="/contact" class="btn btn-primary">Start Collaboration →</a>
          <a href="/portfolio" class="btn btn-outline">View Portfolio</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .gallery-hero {
    padding: clamp(80px,12vw,140px) clamp(20px,5vw,80px);
    background: linear-gradient(180deg, var(--bg) 0%, var(--bg2) 100%);
    position: relative;
    overflow: hidden;
  }

  .gallery-glow {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }

  .gallery-glow-1 {
    top: -100px;
    right: -80px;
    width: clamp(200px,30vw,340px);
    height: clamp(200px,30vw,340px);
    background: radial-gradient(circle, rgba(180,255,87,0.1) 0%, transparent 70%);
    animation: float 6s ease-in-out infinite;
  }

  .gallery-glow-2 {
    bottom: -60px;
    left: -60px;
    width: clamp(150px,22vw,260px);
    height: clamp(150px,22vw,260px);
    background: radial-gradient(circle, rgba(87,255,218,0.08) 0%, transparent 70%);
    animation: float 8s ease-in-out infinite reverse;
  }

  .gallery-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: clamp(20px,4vw,40px);
    margin-top: 48px;
    padding-top: 40px;
    border-top: 1px solid var(--border);
  }

  .stat-num {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 800;
    color: var(--accent);
    margin-bottom: 4px;
    line-height: 1;
  }

  .stat-label {
    font-size: var(--text-xs);
    color: var(--muted2);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-family: var(--font-mono);
  }

  .gallery-showcase {
    padding: clamp(60px,10vw,100px) clamp(20px,5vw,80px);
    background: linear-gradient(180deg, var(--bg2) 0%, var(--bg) 100%);
  }

  .gallery-services {
    padding: clamp(60px,10vw,100px) clamp(20px,5vw,80px);
    background: var(--bg2);
    border-top: 1px solid var(--border);
  }

  .services-bento {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .service-card {
    padding: 28px;
    transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease);
  }

  .service-card:hover {
    transform: translateY(-6px);
  }

  .service-wide {
    grid-column: span 2;
  }

  .service-icon {
    font-size: 40px;
    margin-bottom: 16px;
    line-height: 1;
  }

  .gallery-cta {
    padding: clamp(60px,10vw,100px) clamp(20px,5vw,80px);
  }

  .cta-inner {
    max-width: 700px;
    margin: 0 auto;
    padding: clamp(40px,6vw,72px);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .cta-inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, color-mix(in srgb, var(--accent) 8%, transparent) 0%, transparent 60%);
    pointer-events: none;
  }

  @media (max-width: 900px) {
    .services-bento {
      grid-template-columns: repeat(2, 1fr);
    }
    .service-wide {
      grid-column: span 1;
    }
  }

  @media (max-width: 640px) {
    .services-bento {
      grid-template-columns: 1fr;
    }
    .service-wide {
      grid-column: span 1;
    }
  }

  @media (max-width: 375px) {
    .gallery-hero,
    .gallery-showcase,
    .gallery-services,
    .gallery-cta {
      padding-left: 16px !important;
      padding-right: 16px !important;
    }
  }
</style>

