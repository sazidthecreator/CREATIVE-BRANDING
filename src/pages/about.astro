        </blockquote>

        <div style="display:flex;gap:16px;flex-wrap:wrap;">
          <a href="/contact" class="btn-primary">
            <span class="inline-en">Work With Me →</span>
            <span class="inline-bn" style="font-family:var(--font-bn)">আমার সাথে কাজ করুন →</span>
          </a>
          <a href="/resume" class="btn-ghost">
            <span class="inline-en">View Resume</span>
            <span class="inline-bn" style="font-family:var(--font-bn)">রেজুমে দেখুন</span>
          </a>
        </div>
      </div>

      <!-- Right: Stack Grid -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;" class="reveal stack-grid">
        {stackCards.map((card, i) => (
          <div class="card reveal" style={`padding:20px;animation-delay:${i*0.1}s`}>
            <div style="font-size:22px;margin-bottom:10px;">{card.icon}</div>
            <h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-sm);color:var(--accent);margin-bottom:10px;letter-spacing:0.05em;">
              <span class="inline-en">{card.title}</span>
              <span class="inline-bn" style="font-family:var(--font-bn);font-size:12px;">{card.titleBn}</span>
            </h3>
            <ul style="list-style:none;display:flex;flex-direction:column;gap:4px;">
