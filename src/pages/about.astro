---
import Layout from '../layouts/Layout.astro';

const stackCards = [
  {
    icon: '⚛',
    title: 'Frontend',
    titleBn: 'ফ্রন্টএন্ড',
    items: ['React', 'Next.js', 'TailwindCSS', 'HTML/CSS'],
  },
  {
    icon: '🧩',
    title: 'CMS & No-Code',
    titleBn: 'সিএমএস ও নো-কোড',
    items: ['WordPress', 'Elementor Pro', 'Webflow'],
  },
  {
    icon: '🤖',
    title: 'AI & Automation',
    titleBn: 'এআই ও অটোমেশন',
    items: ['AI Agents', 'n8n/Make', 'WhatsApp API', 'NotebookLM'],
  },
  {
    icon: '🎯',
    title: 'Strategy',
    titleBn: 'স্ট্র্যাটেজি',
    items: ['System Design', 'UX Strategy', 'Sales Funnels', 'SEO Architecture'],
  },
];

const timeline = [
  {
    period: '2023–Present',
    title: 'Founder & AI Automation Strategist',
    titleBn: 'প্রতিষ্ঠাতা ও এআই অটোমেশন স্ট্র্যাটেজিস্ট',
    org: 'Independent / Freelance',
    desc: 'Building AI-native products, automated business systems, and digital identities for startups across Bangladesh and beyond.',
    descBn: 'বাংলাদেশ ও আন্তর্জাতিক স্টার্টআপের জন্য এআই-নেটিভ পণ্য ও অটোমেটেড সিস্টেম তৈরি করছি।',
    side: 'left',
  },
  {
    period: '2022–Present',
    title: 'Web Design Mentor',
    titleBn: 'ওয়েব ডিজাইন মেন্টর',
    org: 'CodemanBD',
    desc: 'Mentoring emerging developers and designers in modern web development, UI/UX principles, and freelance strategy.',
    descBn: 'নতুন ডেভেলপার ও ডিজাইনারদের আধুনিক ওয়েব ডেভেলপমেন্ট ও ফ্রিল্যান্সিং কৌশলে মেন্টরিং করছি।',
    side: 'right',
  },
  {
    period: '2019–Present',
    title: 'Freelance Front-End Developer',
    titleBn: 'ফ্রিল্যান্স ফ্রন্ট-এন্ড ডেভেলপার',
    org: 'Upwork',
    desc: 'Delivering responsive, performant web experiences for clients worldwide — from healthcare platforms to editorial sites.',
    descBn: 'বিশ্বজুড়ে ক্লায়েন্টদের জন্য রেসপনসিভ ও পারফরম্যান্ট ওয়েব এক্সপেরিয়েন্স ডেলিভার করছি।',
    side: 'left',
  },
  {
    period: '2017–2022',
    title: 'BA Philosophy',
    titleBn: 'বিএ দর্শন',
    org: 'Jahangirnagar University',
    desc: 'Graduated with a focus on philosophy of mind, ethics, and logic — disciplines that now shape every system I architect.',
    descBn: 'মন, নীতিশাস্ত্র ও যুক্তিবিদ্যায় বিশেষায়িত হয়ে স্নাতক — এই শাখাগুলো এখন আমার প্রতিটি সিস্টেম আর্কিটেকচারকে রূপ দেয়।',
    side: 'right',
  },
];

const values = [
  { icon: '🎯', title: 'Intention First', titleBn: 'উদ্দেশ্য আগে', desc: 'Every design decision begins with a clear "why" before any "how".' },
  { icon: '⚙️', title: 'Systems Thinking', titleBn: 'সিস্টেমস থিংকিং', desc: 'I see patterns, loops, and leverage points where others see isolated tasks.' },
  { icon: '🤝', title: 'Long-Term Partnership', titleBn: 'দীর্ঘমেয়াদী অংশীদারিত্ব', desc: "I don't just ship projects — I build relationships that compound over time." },
];

const stats = [
  { num: 3, suffix: '+', label: 'Years Experience', labelBn: 'বছরের অভিজ্ঞতা' },
  { num: 32, suffix: '+', label: 'Projects Delivered', labelBn: 'প্রজেক্ট ডেলিভার' },
  { num: 12, suffix: '+', label: 'Industries', labelBn: 'শিল্পখাত' },
];
---

<Layout title="About • Sazid Hossain — Creative Technologist" page="/about">
  <!-- Page Hero: Two-column split -->
  <section class="about-header" style="
    padding: clamp(80px,12vw,140px) clamp(20px,5vw,80px) clamp(48px,6vw,80px);
    background: linear-gradient(180deg, var(--bg) 0%, var(--bg2) 100%);
    position: relative; overflow: clip;
  ">
    <!-- Background accent orb -->
    <div style="
      position:absolute;top:-10%;right:5%;
      width:clamp(300px,45vw,600px);height:clamp(300px,45vw,600px);
      border-radius:50%;
      background:radial-gradient(circle,rgba(87,255,218,0.06) 0%,transparent 70%);
      filter:blur(60px);pointer-events:none;animation:orbDrift 18s ease-in-out infinite;
    "></div>

    <div style="max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:clamp(40px,8vw,100px);align-items:center;" class="about-header-grid">
      <!-- Left: Text -->
      <div class="reveal">
        <p class="section-label">
          <span class="inline-en">About</span>
          <span class="inline-bn" style="font-family:var(--font-bn)">আমার সম্পর্কে</span>
        </p>
        <h1 style="font-family:var(--font-display);font-weight:800;font-size:var(--text-4xl);line-height:1.05;margin-bottom:16px;color:var(--text);">
          <span class="inline-en">The Mind Behind <span class="gradient-text">Nexus</span></span>
          <span class="inline-bn" style="font-family:var(--font-bn)">নেক্সাসের পিছনের <span class="gradient-text">মন</span></span>
        </h1>
        <p style="font-family:var(--font-serif);font-style:italic;font-size:var(--text-xl);color:var(--text2);margin-bottom:32px;line-height:1.6;">
          <span class="inline-en">Philosophy grad. Systems thinker. Web strategist.</span>
          <span class="inline-bn" style="font-family:var(--font-bn);font-style:normal;">দর্শনের ছাত্র। সিস্টেম চিন্তাবিদ। ওয়েব কৌশলবিদ।</span>
        </p>

        <!-- Animated stats -->
        <div style="display:flex;gap:clamp(20px,4vw,40px);margin-bottom:32px;flex-wrap:wrap;">
          {stats.map(s => (
            <div>
              <div
                class="stat-counter"
                data-target={s.num}
                data-suffix={s.suffix}
                style="font-family:var(--font-display);font-weight:800;font-size:var(--text-3xl);color:var(--accent);line-height:1;"
              >
                0{s.suffix}
              </div>
              <div style="font-size:9px;color:var(--muted2);letter-spacing:0.08em;text-transform:uppercase;font-family:var(--font-mono);margin-top:4px;">
                <span class="inline-en">{s.label}</span>
                <span class="inline-bn" style="font-family:var(--font-bn);font-size:10px;">{s.labelBn}</span>
              </div>
            </div>
          ))}
        </div>

        <!-- Scroll indicator -->
        <div style="display:flex;align-items:center;gap:8px;color:var(--muted);font-size:var(--text-xs);font-family:var(--font-mono);">
          <span style="animation:float 2.5s ease-in-out infinite;display:inline-block;">↓</span>
          <span class="inline-en">Scroll to explore</span>
          <span class="inline-bn" style="font-family:var(--font-bn)">স্ক্রোল করুন</span>
        </div>
      </div>

      <!-- Right: CSS Art (concentric circles) -->
      <div class="reveal" style="display:flex;justify-content:center;align-items:center;">
        <div style="position:relative;width:clamp(220px,30vw,340px);height:clamp(220px,30vw,340px);">
