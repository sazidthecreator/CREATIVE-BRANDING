    padding: clamp(80px,12vw,140px) clamp(20px,5vw,80px);
    background: var(--bg2);
    border-top: 1px solid rgba(180,255,87,0.06);
    text-align: center;
    position: relative; overflow: clip;
  " class="reveal">
    <!-- CTA orb -->
    <div style="
      position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
      width:clamp(300px,50vw,600px);height:clamp(300px,50vw,600px);
      border-radius:50%;
      background:radial-gradient(circle,rgba(180,255,87,0.05) 0%,transparent 70%);
      filter:blur(40px);pointer-events:none;
    "></div>
    <div style="max-width:600px;margin:0 auto;position:relative;z-index:1;">
      <h2 style="font-family:var(--font-display);font-weight:800;font-size:var(--text-3xl);margin-bottom:20px;color:var(--text);">
        <span class="inline-en">Let's Create <span class="gradient-text">Together</span></span>
        <span class="inline-bn" style="font-family:var(--font-bn)">একসাথে তৈরি করি</span>
      </h2>
      <p style="font-size:var(--text-base);color:var(--text2);margin-bottom:12px;line-height:1.8;">
        <span class="inline-en">Ready to collaborate? Let's build something meaningful.</span>
        <span class="inline-bn" style="font-family:var(--font-bn)">সহযোগিতার জন্য প্রস্তুত? চলুন কিছু অর্থবহ তৈরি করি।</span>
