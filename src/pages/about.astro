            <div class="card" style="flex:1;padding:20px 24px;">
              <div style="display:flex;gap:10px;align-items:baseline;margin-bottom:8px;flex-wrap:wrap;">
                <span style="
                  font-family:var(--font-mono);font-size:9px;color:var(--accent);
