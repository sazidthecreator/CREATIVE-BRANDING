              </div>
              <h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-lg);color:var(--text);margin-bottom:8px;">
                <span class="inline-en">{item.title}</span>
                <span class="inline-bn" style="font-family:var(--font-bn)">{item.titleBn}</span>
              </h3>
              <p style="font-size:var(--text-sm);color:var(--text2);line-height:1.7;">
                <span class="inline-en">{item.desc}</span>
                <span class="inline-bn" style="font-family:var(--font-bn)">{item.descBn}</span>
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Values -->
  <section style="padding: clamp(80px,12vw,140px) clamp(20px,5vw,80px);" class="reveal">
    <div style="max-width:1200px;margin:0 auto;">
      <p class="section-label">
        <span class="inline-en">What I Stand For</span>
        <span class="inline-bn" style="font-family:var(--font-bn)">আমি যা বিশ্বাস করি</span>
