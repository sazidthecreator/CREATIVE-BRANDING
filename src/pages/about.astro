---
import Layout from '../layouts/Layout.astro';

const stackCards = [
  {
    icon: '⚛',
    title: 'Frontend',
    items: ['React', 'Next.js', 'TailwindCSS', 'HTML/CSS'],
  },
  {
    icon: '🧩',
    title: 'CMS & No-Code',
    items: ['WordPress', 'Elementor Pro', 'Webflow'],
  },
  {
    icon: '🤖',
    title: 'AI & Automation',
    items: ['AI Agents', 'n8n/Make', 'WhatsApp API', 'NotebookLM'],
  },
  {
    icon: '🎯',
    title: 'Strategy',
    items: ['System Design', 'UX Strategy', 'Sales Funnels', 'SEO Architecture'],
  },
];

const timeline = [
  {
    period: '2023–Present',
    title: 'Founder & AI Automation Strategist',
    titleBn: 'প্রতিষ্ঠাতা ও এআই অটোমেশন স্ট্র্যাটেজিস্ট',
    org: 'Independent / Freelance',
    desc: 'Building AI-native products, automated business systems, and digital identities for startups across Bangladesh and beyond.',
    descBn: 'বাংলাদেশ ও আন্তর্জাতিক স্টার্টআপের জন্য এআই-নেটিভ পণ্য ও অটোমেটেড সিস্টেম তৈরি করছি।',
  },
  {
    period: '2022–Present',
    title: 'Web Design Mentor',
    titleBn: 'ওয়েব ডিজাইন মেন্টর',
    org: 'CodemanBD',
    desc: 'Mentoring emerging developers and designers in modern web development, UI/UX principles, and freelance strategy.',
    descBn: 'নতুন ডেভেলপার ও ডিজাইনারদের আধুনিক ওয়েব ডেভেলপমেন্ট ও ফ্রিল্যান্সিং কৌশলে মেন্টরিং করছি।',
  },
  {
    period: '2019–Present',
    title: 'Freelance Front-End Developer',
    titleBn: 'ফ্রিল্যান্স ফ্রন্ট-এন্ড ডেভেলপার',
    org: 'Upwork',
    desc: 'Delivering responsive, performant web experiences for clients worldwide — from healthcare platforms to editorial sites.',
    descBn: 'বিশ্বজুড়ে ক্লায়েন্টদের জন্য রেসপনসিভ ও পারফরম্যান্ট ওয়েব এক্সপেরিয়েন্স ডেলিভার করছি।',
  },
  {
    period: '2017–2022',
    title: 'BA Philosophy',
    titleBn: 'বিএ দর্শন',
    org: 'Jahangirnagar University',
    desc: 'Graduated with a focus on philosophy of mind, ethics, and logic — disciplines that now shape every system I architect.',
    descBn: 'মন, নীতিশাস্ত্র ও যুক্তিবিদ্যায় বিশেষায়িত হয়ে স্নাতক — এই শাখাগুলো এখন আমার প্রতিটি সিস্টেম আর্কিটেকচারকে রূপ দেয়।',
  },
];

const values = [
  { icon: '🎯', title: 'Intention First', titleBn: 'উদ্দেশ্য আগে', desc: 'Every design decision begins with a clear "why" before any "how".' },
  { icon: '⚙️', title: 'Systems Thinking', titleBn: 'সিস্টেমস থিংকিং', desc: 'I see patterns, loops, and leverage points where others see isolated tasks.' },
  { icon: '🤝', title: 'Long-Term Partnership', titleBn: 'দীর্ঘমেয়াদী অংশীদারিত্ব', desc: "I don't just ship projects — I build relationships that compound over time." },
];
---

<Layout title="About • Sazid Hossain — Creative Technologist" page="/about">
  <!-- Page Header -->
  <section class="about-header reveal" style="
    padding: clamp(80px,12vw,140px) clamp(20px,5vw,80px) clamp(48px,6vw,80px);
    background: linear-gradient(180deg, var(--bg) 0%, var(--bg2) 100%);
  ">
    <div style="max-width:1200px;margin:0 auto;">
      <p class="section-label">
        <span class="inline-en">About</span>
        <span class="inline-bn">আমার সম্পর্কে</span>
      </p>
      <h1 style="
        font-family:var(--font-display);font-weight:800;
        font-size:var(--text-4xl);line-height:1.05;
        margin-bottom:16px;color:var(--text);
      ">
        <span class="inline-en">The Mind Behind <span class="gradient-text">Nexus</span></span>
        <span class="inline-bn">নেক্সাসের পিছনের মন</span>
      </h1>
      <p style="
        font-family:var(--font-serif);font-style:italic;
        font-size:var(--text-xl);color:var(--text2);
      ">
        <span class="inline-en">Philosophy grad. Systems thinker. Web strategist.</span>
        <span class="inline-bn">দর্শনের ছাত্র। সিস্টেম চিন্তাবিদ। ওয়েব কৌশলবিদ।</span>
      </p>
    </div>
  </section>

  <!-- Bio + Stack Grid -->
  <section style="
    padding: clamp(60px,10vw,120px) clamp(20px,5vw,80px);
    border-top: 1px solid var(--border);
  ">
    <div style="max-width:1200px;margin:0 auto;display:grid;grid-template-columns:3fr 2fr;gap:clamp(40px,8vw,100px);align-items:start;" class="about-bio-grid">

      <!-- Left: Bio -->
      <div class="reveal">
        <p style="font-size:var(--text-lg);color:var(--text2);line-height:1.8;margin-bottom:20px;">
          <span class="inline-en">
            I'm <strong style="color:var(--text);font-family:var(--font-display);">Sazid Hossain</strong> — a Creative Technologist
            and AI Automation Strategist based in Dhaka, Bangladesh. My journey started in the philosophy
            department of Jahangirnagar University, where I learned to question
            <em style="color:var(--accent);font-family:var(--font-serif);">why</em> before asking
            <em style="color:var(--accent2);font-family:var(--font-serif);">how</em>.
          </span>
          <span class="inline-bn">
            আমি <strong style="color:var(--text);font-family:var(--font-display);">সাজিদ হোসেন</strong> — ঢাকা থেকে ক্রিয়েটিভ টেকনোলজিস্ট
            ও এআই অটোমেশন স্ট্র্যাটেজিস্ট। জাহাঙ্গীরনগর বিশ্ববিদ্যালয়ের দর্শন বিভাগে
            আমার যাত্রা শুরু হয়েছিল।
          </span>
        </p>
        <p style="font-size:var(--text-base);color:var(--text2);line-height:1.8;margin-bottom:20px;">
          <span class="inline-en">
            That philosophical foundation shapes everything I build. When I design a brand, I ask what values
            it represents. When I architect an AI system, I consider what problems it truly solves. When I
            write code, I think about who will maintain it and why.
          </span>
          <span class="inline-bn">
            সেই দার্শনিক ভিত্তি আমার তৈরি প্রতিটি জিনিসকে রূপ দেয়। যখন একটি ব্র্যান্ড ডিজাইন করি,
            জিজ্ঞেস করি এটি কী মূল্যবোধের প্রতিনিধিত্ব করে। যখন একটি এআই সিস্টেম আর্কিটেক্ট করি,
            ভাবি এটি আসলে কোন সমস্যার সমাধান করে।
          </span>
        </p>
        <p style="font-size:var(--text-base);color:var(--text2);line-height:1.8;margin-bottom:28px;">
          <span class="inline-en">
            Today I run a multi-disciplinary practice that blends AI automation, brand strategy, and
            full-stack development — helping founders and businesses build smarter, faster, and more meaningfully.
          </span>
          <span class="inline-bn">
            আজ আমি একটি বহু-বিষয়ক অনুশীলন পরিচালনা করি যা এআই অটোমেশন, ব্র্যান্ড স্ট্র্যাটেজি এবং
            ফুল-স্ট্যাক ডেভেলপমেন্টকে একত্রিত করে।
          </span>
        </p>

        <blockquote style="
          font-family:var(--font-serif);font-style:italic;
          font-size:var(--text-xl);color:var(--text);
          border-left:3px solid var(--accent);padding-left:20px;
          margin-bottom:32px;line-height:1.6;
        ">
          <span class="inline-en">"Philosophy taught me the <span class="gradient-text">Why</span>; Tech taught me the <span style="color:var(--accent2);">How</span>."</span>
          <span class="inline-bn">"দর্শন আমাকে <span class="gradient-text">কেন</span> শিখিয়েছে; প্রযুক্তি শিখিয়েছে <span style="color:var(--accent2);">কীভাবে</span>।"</span>
        </blockquote>

        <div style="display:flex;gap:16px;flex-wrap:wrap;">
          <a href="/contact" class="btn btn-primary">
            <span class="inline-en">Work With Me →</span>
            <span class="inline-bn">আমার সাথে কাজ করুন →</span>
          </a>
          <a href="/resume" class="btn btn-outline">
            <span class="inline-en">View Resume</span>
            <span class="inline-bn">রেজুমে দেখুন</span>
          </a>
        </div>
      </div>

      <!-- Right: Stack Grid -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;" class="reveal stack-grid">
        {stackCards.map(card => (
          <div class="card" style="padding:20px;">
            <div style="font-size:22px;margin-bottom:10px;">{card.icon}</div>
            <h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-sm);color:var(--accent);margin-bottom:10px;letter-spacing:0.05em;">{card.title}</h3>
            <ul style="list-style:none;display:flex;flex-direction:column;gap:4px;">
              {card.items.map(item => (
                <li style="font-size:var(--text-xs);color:var(--text2);font-family:var(--font-mono);">{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section style="
    padding: clamp(80px,12vw,140px) clamp(20px,5vw,80px);
    background: var(--bg2);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  " class="reveal">
    <div style="max-width:800px;margin:0 auto;">
      <p class="section-label">
        <span class="inline-en">Journey</span>
        <span class="inline-bn">যাত্রা</span>
      </p>
      <h2 style="font-family:var(--font-display);font-weight:800;font-size:var(--text-3xl);margin-bottom:clamp(40px,6vw,60px);color:var(--text);">
        <span class="inline-en">Experience &amp; <span class="gradient-text">Education</span></span>
        <span class="inline-bn">অভিজ্ঞতা ও <span class="gradient-text">শিক্ষা</span></span>
      </h2>
      <div style="position:relative;">
        <div style="position:absolute;left:8px;top:0;bottom:0;width:1px;background:linear-gradient(180deg,var(--accent),transparent);"></div>
        {timeline.map((item, i) => (
          <div style="display:flex;gap:24px;margin-bottom:40px;padding-left:8px;" class="reveal">
            <div style="
              width:16px;height:16px;border-radius:50%;
              background:var(--accent);flex-shrink:0;
              margin-top:4px;margin-left:-8px;
              box-shadow:0 0 12px var(--accent-glow);
            "></div>
            <div>
              <div style="display:flex;gap:12px;align-items:baseline;margin-bottom:6px;flex-wrap:wrap;">
                <span style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--accent);">{item.period}</span>
                <h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-lg);color:var(--text);">
                  <span class="inline-en">{item.title}</span>
                  <span class="inline-bn">{item.titleBn}</span>
                </h3>
                <span style="font-size:var(--text-xs);color:var(--muted2);font-family:var(--font-mono);">@ {item.org}</span>
              </div>
              <p style="font-size:var(--text-sm);color:var(--text2);line-height:1.7;">
                <span class="inline-en">{item.desc}</span>
                <span class="inline-bn">{item.descBn}</span>
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Values -->
  <section style="padding: clamp(80px,12vw,140px) clamp(20px,5vw,80px);" class="reveal">
    <div style="max-width:1200px;margin:0 auto;">
      <p class="section-label">
        <span class="inline-en">What I Stand For</span>
        <span class="inline-bn">আমি যা বিশ্বাস করি</span>
      </p>
      <h2 style="font-family:var(--font-display);font-weight:800;font-size:var(--text-3xl);margin-bottom:clamp(40px,6vw,60px);color:var(--text);">
        <span class="inline-en">Core <span class="gradient-text">Values</span></span>
        <span class="inline-bn">মূল <span class="gradient-text">মূল্যবোধ</span></span>
      </h2>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;" class="values-grid">
        {values.map(v => (
          <div class="card" style="padding:36px;text-align:center;">
            <div style="font-size:36px;margin-bottom:16px;">{v.icon}</div>
            <h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-xl);color:var(--text);margin-bottom:4px;">
              <span class="inline-en">{v.title}</span>
              <span class="inline-bn">{v.titleBn}</span>
            </h3>
            <p style="font-size:var(--text-sm);color:var(--text2);line-height:1.6;margin-top:12px;">
              <span class="inline-en">{v.desc}</span>
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Counters -->
  <section class="about-counters reveal" style="
    padding: clamp(60px,10vw,100px) clamp(20px,5vw,80px);
    background: var(--surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  ">
    <div style="max-width:900px;margin:0 auto;">
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;text-align:center;" class="counters-grid">
        <div class="counter-item">
          <div style="
            font-family:var(--font-mono);font-weight:700;
            font-size:clamp(2.5rem,6vw,4rem);
            color:var(--accent);line-height:1;margin-bottom:8px;
          ">
            <span class="counter-number" data-target="6" data-suffix="+">0</span>
          </div>
          <p style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--muted2);text-transform:uppercase;letter-spacing:0.1em;">
            <span class="inline-en">Years</span><span class="inline-bn">বছর</span>
          </p>
        </div>
        <div class="counter-item">
          <div style="
            font-family:var(--font-mono);font-weight:700;
            font-size:clamp(2.5rem,6vw,4rem);
            color:var(--accent2);line-height:1;margin-bottom:8px;
          ">
            <span class="counter-number" data-target="40" data-suffix="+">0</span>
          </div>
          <p style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--muted2);text-transform:uppercase;letter-spacing:0.1em;">
            <span class="inline-en">Projects</span><span class="inline-bn">প্রজেক্ট</span>
          </p>
        </div>
        <div class="counter-item">
          <div style="
            font-family:var(--font-mono);font-weight:700;
            font-size:clamp(2.5rem,6vw,4rem);
            color:var(--accent3);line-height:1;margin-bottom:8px;
          ">
            <span class="counter-number" data-target="100" data-suffix="%">0</span>
          </div>
          <p style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--muted2);text-transform:uppercase;letter-spacing:0.1em;">
            <span class="inline-en">Client Satisfaction</span><span class="inline-bn">ক্লায়েন্ট সন্তুষ্টি</span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="
    padding: clamp(80px,12vw,140px) clamp(20px,5vw,80px);
    background: var(--bg2);
    border-top: 1px solid var(--border);
    text-align: center;
  " class="reveal">
    <div style="max-width:600px;margin:0 auto;">
      <h2 style="font-family:var(--font-display);font-weight:800;font-size:var(--text-3xl);margin-bottom:20px;color:var(--text);">
        <span class="inline-en">Let's Create <span class="gradient-text">Together</span></span>
        <span class="inline-bn">একসাথে তৈরি করি</span>
      </h2>
      <p style="font-size:var(--text-base);color:var(--text2);margin-bottom:12px;">
        <span class="inline-en">Ready to collaborate? Let's build something meaningful.</span>
        <span class="inline-bn">সহযোগিতার জন্য প্রস্তুত? চলুন কিছু অর্থবহ তৈরি করি।</span>
      </p>
      <p style="font-family:var(--font-bn);font-size:var(--text-sm);color:var(--muted);margin-bottom:32px;">
        <span class="inline-bn">আপনার স্বপ্নের প্রজেক্ট নিয়ে কথা বলতে দ্বিধা করবেন না।</span>
      </p>
      <a href="/contact" class="btn btn-primary">
        <span class="inline-en">Get In Touch →</span>
        <span class="inline-bn">যোগাযোগ করুন →</span>
      </a>
    </div>
  </section>
</Layout>

<script>
  // Counter animations using Intersection Observer
  function animateCounter(el: HTMLElement) {
    const target = parseInt(el.dataset.target || '0', 10);
    const suffix = el.dataset.suffix || '';
    const COUNTER_ANIMATION_DURATION_MS = 1600;
    const start = performance.now();

    function step(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / COUNTER_ANIMATION_DURATION_MS, 1);
      // Ease out cubic
      const eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.round(eased * target) + suffix;
      if (progress < 1) requestAnimationFrame(step);
    }

    requestAnimationFrame(step);
  }

  const counterObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        animateCounter(el);
        counterObserver.unobserve(el);
      }
    });
  }, { threshold: 0.5 });

  document.querySelectorAll<HTMLElement>('.counter-number').forEach(el => {
    counterObserver.observe(el);
  });
</script>

<style>
  @media (max-width: 768px) {
    .about-bio-grid { grid-template-columns: 1fr !important; }
    .values-grid { grid-template-columns: 1fr !important; }
    .stack-grid { grid-template-columns: 1fr 1fr !important; }
    .counters-grid { grid-template-columns: 1fr 1fr !important; }
  }
  @media (max-width: 480px) {
    .stack-grid { grid-template-columns: 1fr !important; }
    .counters-grid { grid-template-columns: 1fr !important; }
  }
</style>

