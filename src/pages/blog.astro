---
import Layout from '../layouts/Layout.astro';

const posts = [
  {
    slug: 'philosophy-of-ai-design',
    title: 'The Philosophy of AI-Driven Design',
    titleBn: 'এআই-চালিত ডিজাইনের দর্শন',
    excerpt: 'How Kantian ethics and phenomenology can guide responsible AI system design in 2025.',
    excerptBn: 'কান্টিয়ান নৈতিকতা কীভাবে ২০২৫ সালের এআই ডিজাইনকে গাইড করতে পারে।',
    date: '2025-02-15',
    readTime: '8 min read',
    category: 'Philosophy',
    emoji: '🧠',
    featured: true,
  },
  {
    slug: 'bilingual-ux-bangladesh',
    title: 'Bilingual UX: Designing for Bangladesh',
    titleBn: 'দ্বিভাষিক UX: বাংলাদেশের জন্য ডিজাইন',
    excerpt: 'The unique challenges and opportunities of building digital products that serve both English and Bengali speakers.',
    excerptBn: 'ইংরেজি ও বাংলা উভয় ব্যবহারকারীর জন্য পণ্য তৈরির চ্যালেঞ্জ ও সুযোগ।',
    date: '2025-01-28',
    readTime: '6 min read',
    category: 'Design',
    emoji: '🌐',
    featured: true,
  },
  {
    slug: 'ai-automation-stack-2025',
    title: 'My AI Automation Stack in 2025',
    titleBn: '২০২৫ সালে আমার এআই অটোমেশন স্ট্যাক',
    excerpt: 'n8n, Make.com, OpenAI, and Airtable — the tools I use to automate business workflows.',
    excerptBn: 'n8n, Make.com, OpenAI — ব্যবসায়িক ওয়ার্কফ্লো অটোমেট করতে আমি যা ব্যবহার করি।',
    date: '2025-01-10',
    readTime: '5 min read',
    category: 'Tech',
    emoji: '⚡',
    featured: false,
  },
  {
    slug: 'brand-vs-identity',
    title: 'Brand vs. Identity: The Crucial Difference',
    titleBn: 'ব্র্যান্ড বনাম আইডেন্টিটি: গুরুত্বপূর্ণ পার্থক্য',
    excerpt: 'Most designers confuse brand with visual identity. Here\'s why that confusion costs clients millions.',
    excerptBn: 'বেশিরভাগ ডিজাইনার ব্র্যান্ড ও ভিজ্যুয়াল আইডেন্টিটি গুলিয়ে ফেলেন।',
    date: '2024-12-20',
    readTime: '7 min read',
    category: 'Branding',
    emoji: '◈',
    featured: false,
  },
  {
    slug: 'astro-vs-nextjs',
    title: 'Astro vs Next.js: Which Should You Choose?',
    titleBn: 'Astro বনাম Next.js: কোনটি বেছে নেবেন?',
    excerpt: 'A practical comparison from someone who has shipped production sites with both frameworks.',
    excerptBn: 'উভয় ফ্রেমওয়ার্কে প্রোডাকশন সাইট শিপ করার পর একটি ব্যবহারিক তুলনা।',
    date: '2024-12-05',
    readTime: '10 min read',
    category: 'Tech',
    emoji: '⚗',
    featured: false,
  },
];

const categories = ['All', ...new Set(posts.map(p => p.category))];
const featuredPosts = posts.filter(p => p.featured);
---

<Layout title="Blog • Sazid Hossain — Philosophy Meets Technology" page="/blog">
  <!-- Hero -->
  <section style="
    padding: clamp(80px,12vw,140px) clamp(20px,5vw,80px);
    background: linear-gradient(180deg, var(--bg) 0%, var(--bg2) 100%);
  ">
    <div style="max-width:1200px;margin:0 auto;">
      <p class="section-label">Blog</p>
      <h1 style="
        font-family:var(--font-display);font-weight:800;
        font-size:var(--text-4xl);line-height:1.05;
        margin-bottom:20px;color:var(--text);
      ">
        Thoughts on <span class="gradient-text">Design & Technology</span>
      </h1>
      <p style="font-size:var(--text-lg);color:var(--text2);max-width:560px;line-height:1.8;margin-bottom:8px;">
        Essays on AI, design systems, philosophy, and building digital products in Bangladesh.
      </p>
      <p style="font-family:var(--font-bn);font-size:var(--text-base);color:var(--muted);">
        ডিজাইন, প্রযুক্তি এবং দর্শন নিয়ে প্রবন্ধ।
      </p>
    </div>
  </section>

  <!-- Featured Posts -->
  <section style="padding: clamp(60px,10vw,100px) clamp(20px,5vw,80px) 40px;">
    <div style="max-width:1200px;margin:0 auto;">
      <p class="section-label">Featured</p>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:28px;margin-top:28px;" class="featured-grid">
        {featuredPosts.map((post, i) => (
          <a href={`/blog/${post.slug}`} style="text-decoration:none;color:inherit;" class="reveal" style={`animation-delay:${i*0.1}s`}>
            <div class="card" style="padding:36px;height:100%;">
              <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px;">
                <div style="
                  width:52px;height:52px;border-radius:12px;
                  background:var(--accent-dim);
                  display:flex;align-items:center;justify-content:center;
                  font-size:24px;
                ">{post.emoji}</div>
                <span style="
                  padding:4px 10px;border-radius:99px;
                  background:var(--accent-dim);color:var(--accent);
                  font-size:var(--text-xs);font-family:var(--font-mono);
                  border:1px solid rgba(180,255,87,0.15);
                ">{post.category}</span>
              </div>
              <h2 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-xl);color:var(--text);margin-bottom:8px;line-height:1.4;">{post.title}</h2>
              <p style="font-family:var(--font-bn);font-size:var(--text-sm);color:var(--muted);margin-bottom:12px;">{post.titleBn}</p>
              <p style="font-size:var(--text-sm);color:var(--text2);line-height:1.7;margin-bottom:24px;">{post.excerpt}</p>
              <div style="display:flex;justify-content:space-between;align-items:center;margin-top:auto;border-top:1px solid var(--border);padding-top:16px;">
                <span style="font-size:var(--text-xs);color:var(--muted);font-family:var(--font-mono);">{post.date}</span>
                <span style="font-size:var(--text-xs);color:var(--accent);font-family:var(--font-mono);">{post.readTime}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- All Posts -->
  <section style="padding: 40px clamp(20px,5vw,80px) clamp(80px,12vw,140px);">
    <div style="max-width:1200px;margin:0 auto;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:32px;flex-wrap:wrap;gap:16px;">
        <p class="section-label" style="margin-bottom:0;">All Posts</p>
        <!-- Category filter -->
        <div style="display:flex;gap:8px;flex-wrap:wrap;">
          {categories.map((cat, i) => (
            <button
              class={`blog-filter${i === 0 ? ' active' : ''}`}
              data-cat={cat}
              style="
                padding:6px 16px;border-radius:99px;cursor:pointer;
                font-size:var(--text-xs);font-family:var(--font-mono);
                letter-spacing:0.08em;transition:all 0.2s;
                border:1px solid var(--border2);background:transparent;color:var(--muted2);
              "
            >
              {cat}
            </button>
          ))}
        </div>
      </div>

      <div style="display:flex;flex-direction:column;gap:16px;" id="postsContainer">
        {posts.map((post, i) => (
          <a href={`/blog/${post.slug}`} style="text-decoration:none;color:inherit;" class={`post-item reveal`} data-cat={post.category} style={`animation-delay:${i*0.05}s`}>
            <div class="card" style="padding:24px 28px;">
              <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;">
                <span style="font-size:20px;flex-shrink:0;">{post.emoji}</span>
                <div style="flex:1;min-width:200px;">
                  <div style="display:flex;gap:12px;align-items:baseline;flex-wrap:wrap;margin-bottom:4px;">
                    <h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-base);color:var(--text);">{post.title}</h3>
                    <span style="font-size:var(--text-xs);color:var(--muted);font-family:var(--font-bn);">{post.titleBn}</span>
                  </div>
                  <p style="font-size:var(--text-sm);color:var(--muted2);line-height:1.5;">{post.excerpt}</p>
                </div>
                <div style="display:flex;flex-direction:column;align-items:flex-end;gap:6px;flex-shrink:0;">
                  <span style="padding:3px 10px;border-radius:99px;background:var(--accent-dim);color:var(--accent);font-size:var(--text-xs);font-family:var(--font-mono);">{post.category}</span>
                  <span style="font-size:var(--text-xs);color:var(--muted);font-family:var(--font-mono);">{post.readTime}</span>
                  <span style="font-size:var(--text-xs);color:var(--muted);">{post.date}</span>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  const filters = document.querySelectorAll('.blog-filter');
  const posts = document.querySelectorAll('.post-item');

  filters.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = (btn as HTMLElement).dataset.cat;
      filters.forEach(b => {
        (b as HTMLElement).style.background = 'transparent';
        (b as HTMLElement).style.color = 'var(--muted2)';
        (b as HTMLElement).style.borderColor = 'var(--border2)';
      });
      (btn as HTMLElement).style.background = 'var(--accent-dim)';
      (btn as HTMLElement).style.color = 'var(--accent)';
      (btn as HTMLElement).style.borderColor = 'rgba(180,255,87,0.3)';

      posts.forEach(post => {
        const el = post as HTMLElement;
        el.style.display = cat === 'All' || el.dataset.cat === cat ? 'block' : 'none';
      });
    });
  });

  // Init active
  const active = document.querySelector('.blog-filter.active') as HTMLElement;
  if (active) {
    active.style.background = 'var(--accent-dim)';
    active.style.color = 'var(--accent)';
    active.style.borderColor = 'rgba(180,255,87,0.3)';
  }
</script>

<style>
  @media (max-width: 640px) {
    .featured-grid { grid-template-columns: 1fr !important; }
  }
</style>
