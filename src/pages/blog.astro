---
import Layout from '../layouts/Layout.astro';

const posts = [
  {
    slug: 'philosophy-technology',
    title: 'Philosophy × Technology: A Necessary Union',
    titleBn: 'দর্শন × প্রযুক্তি: একটি অপরিহার্য মিলন',
    excerpt: 'How the ancient practice of asking "why" is the most powerful tool in a technologist\'s arsenal.',
    excerptBn: '"কেন" জিজ্ঞেস করার প্রাচীন অভ্যাসটি একজন প্রযুক্তিবিদের সবচেয়ে শক্তিশালী হাতিয়ার।',
    date: '2025-03-01',
    readTime: '9 min read',
    category: 'Philosophy',
    tags: ['Philosophy', 'Tech', 'Systems'],
    emoji: '🧠',
    featured: true,
    number: '01',
  },
  {
    slug: 'philosophy-of-ai-design',
    title: 'The Philosophy of AI-Driven Design',
    titleBn: 'এআই-চালিত ডিজাইনের দর্শন',
    excerpt: 'How Kantian ethics and phenomenology can guide responsible AI system design in 2025.',
    excerptBn: 'কান্টিয়ান নৈতিকতা কীভাবে ২০২৫ সালের এআই ডিজাইনকে গাইড করতে পারে।',
    date: '2025-02-15',
    readTime: '8 min read',
    category: 'Philosophy',
    tags: ['AI', 'Ethics', 'Design'],
    emoji: '🤖',
    featured: false,
    number: '02',
  },
  {
    slug: 'bilingual-ux-bangladesh',
    title: 'Bilingual UX: Designing for Bangladesh',
    titleBn: 'দ্বিভাষিক UX: বাংলাদেশের জন্য ডিজাইন',
    excerpt: 'The unique challenges and opportunities of building digital products that serve both English and Bengali speakers.',
    excerptBn: 'ইংরেজি ও বাংলা উভয় ব্যবহারকারীর জন্য পণ্য তৈরির চ্যালেঞ্জ ও সুযোগ।',
    date: '2025-01-28',
    readTime: '6 min read',
    category: 'Bangladesh',
    tags: ['UX', 'Bangla', 'Localization'],
    emoji: '🌐',
    featured: false,
    number: '03',
  },
  {
    slug: 'ai-automation-stack-2025',
    title: 'My AI Automation Stack in 2025',
    titleBn: '২০২৫ সালে আমার এআই অটোমেশন স্ট্যাক',
    excerpt: 'n8n, Make.com, OpenAI, and Airtable — the tools I use to automate business workflows.',
    excerptBn: 'n8n, Make.com, OpenAI — ব্যবসায়িক ওয়ার্কফ্লো অটোমেট করতে আমি যা ব্যবহার করি।',
    date: '2025-01-10',
    readTime: '5 min read',
    category: 'Product Notes',
    tags: ['n8n', 'Automation', 'AI'],
    emoji: '⚡',
    featured: false,
    number: '04',
  },
  {
    slug: 'brand-vs-identity',
    title: 'Brand vs. Identity: The Crucial Difference',
    titleBn: 'ব্র্যান্ড বনাম আইডেন্টিটি: গুরুত্বপূর্ণ পার্থক্য',
    excerpt: 'Most designers confuse brand with visual identity. Here\'s why that confusion costs clients millions.',
    excerptBn: 'বেশিরভাগ ডিজাইনার ব্র্যান্ড ও ভিজ্যুয়াল আইডেন্টিটি গুলিয়ে ফেলেন।',
    date: '2024-12-20',
    readTime: '7 min read',
    category: 'Work & Life',
    tags: ['Branding', 'Strategy'],
    emoji: '◈',
    featured: false,
    number: '05',
  },
  {
    slug: 'astro-vs-nextjs',
    title: 'Astro vs Next.js: Which Should You Choose?',
    titleBn: 'Astro বনাম Next.js: কোনটি বেছে নেবেন?',
    excerpt: 'A practical comparison from someone who has shipped production sites with both frameworks.',
    excerptBn: 'উভয় ফ্রেমওয়ার্কে প্রোডাকশন সাইট শিপ করার পর একটি ব্যবহারিক তুলনা।',
    date: '2024-12-05',
    readTime: '10 min read',
    category: 'Learning',
    tags: ['Astro', 'Next.js', 'Web Dev'],
    emoji: '⚗',
    featured: false,
    number: '06',
  },
  {
    slug: 'systems-thinking-for-freelancers',
    title: 'Systems Thinking for Freelancers',
    titleBn: 'ফ্রিল্যান্সারদের জন্য সিস্টেমস থিংকিং',
    excerpt: 'How thinking in systems rather than projects transforms your freelance practice.',
    excerptBn: 'প্রজেক্টের পরিবর্তে সিস্টেমে চিন্তা করা কীভাবে আপনার ফ্রিল্যান্স অনুশীলনকে রূপান্তরিত করে।',
    date: '2024-11-14',
    readTime: '6 min read',
    category: 'Work & Life',
    tags: ['Freelance', 'Systems', 'Productivity'],
    emoji: '⚙️',
    featured: false,
    number: '07',
  },
  {
    slug: 'building-dhaka-startup',
    title: 'What It Really Takes to Build a Dhaka Startup',
    titleBn: 'ঢাকায় স্টার্টআপ গড়তে সত্যিই কী লাগে',
    excerpt: 'Navigating infrastructure, talent, and capital constraints in Bangladesh\'s startup ecosystem.',
    excerptBn: 'বাংলাদেশের স্টার্টআপ ইকোসিস্টেমে অবকাঠামো, প্রতিভা ও মূলধনের চ্যালেঞ্জ।',
    date: '2024-10-20',
    readTime: '8 min read',
    category: 'Bangladesh',
    tags: ['Bangladesh', 'Startup', 'Ecosystem'],
    emoji: '🏙️',
    featured: false,
    number: '08',
  },
];

const microEssays = [
  { title: 'On Clarity', content: 'Complexity is a failure of explanation, not a sign of depth.', date: 'Feb 2025' },
  { title: 'On Shipping', content: 'Done is a compass. Perfect is a loop.', date: 'Jan 2025' },
  { title: 'On AI', content: 'AI is not a replacement for thinking. It\'s a mirror for it.', date: 'Jan 2025' },
  { title: 'On Design', content: 'Every pixel is a decision. Every decision is a value judgment.', date: 'Dec 2024' },
];

const categoryLinks = [
  { name: 'All Essays', count: posts.length },
  { name: 'Work & Life', count: posts.filter(p => p.category === 'Work & Life').length },
  { name: 'Product Notes', count: posts.filter(p => p.category === 'Product Notes').length },
  { name: 'Learning', count: posts.filter(p => p.category === 'Learning').length },
  { name: 'Bangladesh', count: posts.filter(p => p.category === 'Bangladesh').length },
  { name: 'Philosophy', count: posts.filter(p => p.category === 'Philosophy').length },
];

const recentPosts = posts.slice(0, 4);
const featuredPost = posts.find(p => p.featured);
const INITIAL_COUNT = 4;

// Dynamic stats
const totalEssayCount = posts.length + '+';
const avgReadMin = Math.round(posts.reduce((sum, p) => sum + parseInt(p.readTime), 0) / posts.length);
const uniqueCategories = new Set(posts.map(p => p.category)).size;
---

<Layout title="Blog • Sazid Hossain — Philosophy Meets Technology" page="/blog">
  <!-- Hero -->
  <section style="
    padding: clamp(80px,12vw,140px) clamp(20px,5vw,80px) clamp(40px,6vw,60px);
    background: linear-gradient(180deg, var(--bg) 0%, var(--bg2) 100%);
  ">
    <div style="max-width:1200px;margin:0 auto;">
      <p class="section-label">
        <span class="inline-en">Blog</span>
        <span class="inline-bn">ব্লগ</span>
      </p>
      <h1 style="
        font-family:var(--font-display);font-weight:800;
        font-size:var(--text-4xl);line-height:1.05;
        margin-bottom:20px;color:var(--text);
      ">
        <span class="inline-en">Thoughts on <span class="gradient-text">Design &amp; Technology</span></span>
        <span class="inline-bn"><span class="gradient-text">ডিজাইন ও প্রযুক্তি</span> নিয়ে চিন্তা</span>
      </h1>
      <p style="font-size:var(--text-lg);color:var(--text2);max-width:560px;line-height:1.8;margin-bottom:8px;">
        <span class="inline-en">Essays on AI, design systems, philosophy, and building digital products in Bangladesh.</span>
        <span class="inline-bn">এআই, ডিজাইন সিস্টেম, দর্শন ও বাংলাদেশে ডিজিটাল পণ্য তৈরি নিয়ে প্রবন্ধ।</span>
      </p>

      <!-- Stats Row -->
      <div style="display:flex;gap:40px;margin-top:36px;flex-wrap:wrap;" class="blog-stats">
        {[
          { num: totalEssayCount, label: 'Essays Published', labelBn: 'প্রবন্ধ প্রকাশিত' },
          { num: `${avgReadMin} min`, label: 'Average Read', labelBn: 'গড় পড়ার সময়' },
          { num: String(uniqueCategories), label: 'Core Themes', labelBn: 'মূল থিম' },
        ].map(s => (
          <div>
            <div style="font-family:var(--font-display);font-weight:800;font-size:var(--text-2xl);color:var(--accent);">{s.num}</div>
            <div style="font-size:var(--text-xs);color:var(--muted2);font-family:var(--font-mono);letter-spacing:0.1em;text-transform:uppercase;margin-top:2px;">
              <span class="inline-en">{s.label}</span>
              <span class="inline-bn">{s.labelBn}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Post (large banner) -->
  {featuredPost && (
    <section style="padding: clamp(40px,6vw,60px) clamp(20px,5vw,80px) 0;" class="reveal">
      <div style="max-width:1200px;margin:0 auto;">
        <p class="section-label">
          <span class="inline-en">Featured Essay</span>
          <span class="inline-bn">বৈশিষ্ট্যযুক্ত প্রবন্ধ</span>
        </p>
        <a href={`/blog/${featuredPost.slug}`} style="text-decoration:none;color:inherit;display:block;">
          <div class="card" style="
            padding: clamp(28px,5vw,48px);
            background: linear-gradient(135deg, var(--surface) 0%, var(--surface2) 100%);
            position: relative; overflow: hidden;
          ">
            <div style="
              position:absolute;right:-60px;top:-60px;
              width:220px;height:220px;border-radius:50%;
              background:radial-gradient(circle,rgba(180,255,87,0.1) 0%,transparent 70%);
            "></div>
            <div style="display:flex;gap:16px;align-items:flex-start;flex-wrap:wrap;position:relative;z-index:1;">
              <div style="
                width:64px;height:64px;border-radius:14px;
                background:var(--accent-dim);border:1px solid rgba(180,255,87,0.2);
                display:flex;align-items:center;justify-content:center;
                font-size:30px;flex-shrink:0;
              ">{featuredPost.emoji}</div>
              <div style="flex:1;min-width:200px;">
                <div style="display:flex;gap:10px;align-items:center;margin-bottom:12px;flex-wrap:wrap;">
                  <span style="
                    padding:3px 10px;border-radius:99px;
                    background:var(--accent-dim);color:var(--accent);
                    font-size:var(--text-xs);font-family:var(--font-mono);
                    border:1px solid rgba(180,255,87,0.2);
                  ">{featuredPost.category}</span>
                  <span style="font-size:var(--text-xs);color:var(--muted);font-family:var(--font-mono);">{featuredPost.readTime}</span>
                </div>
                <h2 style="font-family:var(--font-display);font-weight:800;font-size:var(--text-2xl);color:var(--text);margin-bottom:8px;line-height:1.3;">
                  <span class="inline-en">{featuredPost.title}</span>
                  <span class="inline-bn">{featuredPost.titleBn}</span>
                </h2>
                <p style="font-size:var(--text-base);color:var(--text2);line-height:1.7;margin-bottom:16px;">
                  <span class="inline-en">{featuredPost.excerpt}</span>
                  <span class="inline-bn">{featuredPost.excerptBn}</span>
                </p>
                <div style="display:flex;gap:8px;flex-wrap:wrap;">
                  {featuredPost.tags.map(tag => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- Two-column Layout: Posts + Sidebar -->
  <section style="padding: clamp(40px,6vw,60px) clamp(20px,5vw,80px) clamp(80px,12vw,140px);">
    <div style="max-width:1200px;margin:0 auto;display:grid;grid-template-columns:2fr 1fr;gap:48px;align-items:start;" class="blog-main-grid">

      <!-- Left: Posts -->
      <div>
        <!-- Filter chips -->
        <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:20px;" id="filterChips">
          {['All Essays', 'Work & Life', 'Product Notes', 'Learning', 'Bangladesh', 'Philosophy'].map((cat, i) => (
            <button
              class={`blog-chip${i === 0 ? ' active' : ''}`}
              data-filter={cat}
              style="
                padding:7px 18px;border-radius:99px;cursor:pointer;
                font-size:var(--text-xs);font-family:var(--font-mono);
                letter-spacing:0.08em;transition:all 0.18s;
                border:1px solid var(--border2);background:transparent;color:var(--muted2);
              "
            >{cat}</button>
          ))}
        </div>

        <!-- Search + Sort + Reset -->
        <div style="display:flex;gap:10px;align-items:center;margin-bottom:16px;flex-wrap:wrap;">
          <input
            type="text"
            id="blogSearch"
            placeholder="Search essays…"
            style="
              flex:1;min-width:160px;padding:9px 14px;
              background:var(--surface2);border:1px solid var(--border2);
              border-radius:8px;color:var(--text);font-size:var(--text-sm);
              font-family:var(--font-body);outline:none;transition:border-color 0.2s;
            "
          />
          <select id="blogSort" style="
            padding:9px 12px;background:var(--surface2);border:1px solid var(--border2);
            border-radius:8px;color:var(--text2);font-size:var(--text-sm);
            font-family:var(--font-body);outline:none;cursor:pointer;
          ">
            <option value="newest">Newest First</option>
            <option value="oldest">Oldest First</option>
            <option value="longest">Longest Read</option>
          </select>
          <button id="blogReset" style="
            padding:9px 14px;border-radius:8px;
            border:1px solid var(--border2);background:transparent;
            color:var(--muted2);font-size:var(--text-sm);cursor:pointer;
            transition:all 0.2s;
          ">Reset</button>
        </div>

        <!-- Results count -->
        <p id="resultsCount" style="font-size:var(--text-xs);color:var(--muted);font-family:var(--font-mono);margin-bottom:20px;"></p>

        <!-- Editor Note -->
        <div style="
          padding:16px 20px;border-radius:10px;
          background:var(--accent-dim);border:1px solid rgba(180,255,87,0.15);
          margin-bottom:24px;display:flex;gap:12px;align-items:flex-start;
        ">
          <span style="font-size:18px;flex-shrink:0;">✍️</span>
          <div>
            <p style="font-family:var(--font-display);font-weight:700;font-size:var(--text-xs);color:var(--accent);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:4px;">This Month</p>
            <p style="font-size:var(--text-sm);color:var(--text2);line-height:1.6;">
              <span class="inline-en">Exploring the intersection of philosophy and technology. New essays on systems thinking and Bangladesh's digital future.</span>
              <span class="inline-bn">দর্শন ও প্রযুক্তির সংযোগস্থল অন্বেষণ করছি। সিস্টেমস থিংকিং এবং বাংলাদেশের ডিজিটাল ভবিষ্যৎ নিয়ে নতুন প্রবন্ধ।</span>
            </p>
          </div>
        </div>

        <!-- Posts List -->
        <div id="postsContainer" style="display:flex;flex-direction:column;gap:16px;">
          {posts.map((post, i) => (
            <a
              href={`/blog/${post.slug}`}
              style="text-decoration:none;color:inherit;"
              class="post-item reveal"
              data-category={post.category}
              data-title={post.title.toLowerCase()}
              data-date={post.date}
              data-read={post.readTime}
              data-idx={i}
              style={i >= INITIAL_COUNT ? 'display:none' : ''}
            >
              <div class="card" style="padding:22px 26px;transition:all 0.25s;">
                <div style="display:flex;align-items:flex-start;gap:16px;flex-wrap:wrap;">
                  <span style="
                    font-family:var(--font-mono);font-size:var(--text-xs);
                    color:var(--accent);min-width:28px;padding-top:2px;flex-shrink:0;
                  ">{post.number}</span>
                  <span style="font-size:20px;flex-shrink:0;">{post.emoji}</span>
                  <div style="flex:1;min-width:180px;">
                    <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-bottom:4px;">
                      <span style="
                        padding:2px 9px;border-radius:99px;
                        background:var(--accent-dim);color:var(--accent);
                        font-size:var(--text-xs);font-family:var(--font-mono);
                        border:1px solid rgba(180,255,87,0.15);
                      ">{post.category}</span>
                    </div>
                    <h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-base);color:var(--text);margin-bottom:4px;line-height:1.35;">
                      <span class="inline-en">{post.title}</span>
                      <span class="inline-bn">{post.titleBn}</span>
                    </h3>
                    <p style="font-size:var(--text-sm);color:var(--muted2);line-height:1.5;margin-bottom:10px;">
                      <span class="inline-en">{post.excerpt}</span>
                      <span class="inline-bn">{post.excerptBn}</span>
                    </p>
                    <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;">
                      <span style="font-size:var(--text-xs);color:var(--muted);font-family:var(--font-mono);">{post.date}</span>
                      <span style="font-size:var(--text-xs);color:var(--accent);font-family:var(--font-mono);">{post.readTime}</span>
                      <div style="display:flex;gap:4px;flex-wrap:wrap;">
                        {post.tags.map(tag => (
                          <span class="tag" style="font-size:9px;padding:2px 8px;">{tag}</span>
                        ))}
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>

        <!-- Empty State -->
        <div id="emptyState" style="display:none;text-align:center;padding:60px 0;">
          <div style="font-size:40px;margin-bottom:12px;">📭</div>
          <p style="font-size:var(--text-base);color:var(--muted2);">No essays match your search.</p>
        </div>

        <!-- Load More -->
        <div style="text-align:center;margin-top:28px;" id="loadMoreWrap">
          <button id="loadMoreBtn" class="btn btn-outline" style="min-width:180px;">
            <span class="inline-en">Load More Essays</span>
            <span class="inline-bn">আরও প্রবন্ধ দেখুন</span>
          </button>
        </div>

        <!-- Micro Essays -->
        <div style="margin-top:60px;" class="reveal">
          <p class="section-label">
            <span class="inline-en">Micro Essays</span>
            <span class="inline-bn">মাইক্রো প্রবন্ধ</span>
          </p>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;" class="micro-grid">
            {microEssays.map(m => (
              <div class="card" style="padding:20px;">
                <h4 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-sm);color:var(--accent);margin-bottom:8px;">{m.title}</h4>
                <p style="font-size:var(--text-sm);color:var(--text2);line-height:1.6;font-style:italic;font-family:var(--font-serif);">"{m.content}"</p>
                <p style="font-size:var(--text-xs);color:var(--muted);font-family:var(--font-mono);margin-top:10px;">{m.date}</p>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <aside style="position:sticky;top:80px;display:flex;flex-direction:column;gap:24px;" class="blog-sidebar">

        <!-- Categories -->
        <div class="card" style="padding:22px;">
          <h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-sm);color:var(--text);margin-bottom:16px;letter-spacing:0.05em;">
            <span class="inline-en">Categories</span>
            <span class="inline-bn">বিভাগ</span>
          </h3>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:8px;">
            {categoryLinks.map(cl => (
              <li style="display:flex;justify-content:space-between;align-items:center;">
                <button class="sidebar-cat-btn" data-cat={cl.name} style="
                  background:none;border:none;cursor:pointer;
                  font-size:var(--text-sm);color:var(--text2);text-align:left;
                  padding:0;transition:color 0.2s;
                ">{cl.name}</button>
                <span style="font-size:var(--text-xs);color:var(--muted);font-family:var(--font-mono);">{cl.count}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Recent Posts -->
        <div class="card" style="padding:22px;">
          <h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-sm);color:var(--text);margin-bottom:16px;">
            <span class="inline-en">Recent Posts</span>
            <span class="inline-bn">সাম্প্রতিক পোস্ট</span>
          </h3>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:12px;">
            {recentPosts.map(post => (
              <li>
                <a href={`/blog/${post.slug}`} style="text-decoration:none;display:flex;gap:10px;align-items:flex-start;">
                  <span style="font-size:16px;flex-shrink:0;">{post.emoji}</span>
                  <div>
                    <p style="font-size:var(--text-xs);color:var(--text2);line-height:1.4;margin-bottom:2px;transition:color 0.2s;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text2)'">
                      <span class="inline-en">{post.title}</span>
                      <span class="inline-bn">{post.titleBn}</span>
                    </p>
                    <p style="font-size:9px;color:var(--muted);font-family:var(--font-mono);">{post.date}</p>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Subscribe -->
        <div class="card" style="padding:22px;background:linear-gradient(135deg,var(--surface) 0%,var(--surface2) 100%);">
          <h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-sm);color:var(--text);margin-bottom:8px;">
            <span class="inline-en">Stay Updated</span>
            <span class="inline-bn">আপডেট থাকুন</span>
          </h3>
          <p style="font-size:var(--text-xs);color:var(--muted2);margin-bottom:14px;line-height:1.5;">
            <span class="inline-en">New essays, every week or two.</span>
            <span class="inline-bn">প্রতি সপ্তাহে বা দুই সপ্তাহে নতুন প্রবন্ধ।</span>
          </p>
          <div id="subscribeForm">
            <input
              type="email"
              id="subscribeEmail"
              placeholder="your@email.com"
              style="
                width:100%;padding:9px 12px;
                background:var(--surface2);border:1px solid var(--border2);
                border-radius:7px;color:var(--text);font-size:var(--text-sm);
                outline:none;transition:border-color 0.2s;margin-bottom:8px;
              "
            />
            <button id="subscribeBtn" class="btn btn-primary" style="width:100%;justify-content:center;padding:10px;">
              <span class="inline-en">Subscribe →</span>
              <span class="inline-bn">সাবস্ক্রাইব করুন →</span>
            </button>
          </div>
          <p id="subscribeFeedback" style="display:none;font-size:var(--text-xs);color:var(--accent);text-align:center;margin-top:8px;"></p>
        </div>

        <!-- Philosophy Ticker -->
        <div class="card" style="padding:20px;overflow:hidden;">
          <h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-xs);color:var(--muted);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:12px;">Philosophy Ticker</h3>
          <p id="ticker" style="font-family:var(--font-serif);font-style:italic;font-size:var(--text-sm);color:var(--text2);line-height:1.6;transition:opacity 0.5s;"></p>
        </div>

      </aside>
    </div>
  </section>
</Layout>

<script>
  const postsData = document.querySelectorAll<HTMLElement>('.post-item');
  const chips = document.querySelectorAll<HTMLElement>('.blog-chip');
  const sidebarCatBtns = document.querySelectorAll<HTMLElement>('.sidebar-cat-btn');
  const searchInput = document.getElementById('blogSearch') as HTMLInputElement;
  const sortSelect = document.getElementById('blogSort') as HTMLSelectElement;
  const resetBtn = document.getElementById('blogReset') as HTMLButtonElement;
  const resultsCount = document.getElementById('resultsCount') as HTMLElement;
  const emptyState = document.getElementById('emptyState') as HTMLElement;
  const loadMoreBtn = document.getElementById('loadMoreBtn') as HTMLButtonElement;
  const loadMoreWrap = document.getElementById('loadMoreWrap') as HTMLElement;

  const INITIAL_VISIBLE = 4;
  let activeFilter = 'All Essays';
  let visibleCount = INITIAL_VISIBLE;

  function getPostsFiltered(): HTMLElement[] {
    const search = searchInput.value.toLowerCase();
    return Array.from(postsData).filter(post => {
      const cat = post.dataset.category || '';
      const title = post.dataset.title || '';
      const matchFilter = activeFilter === 'All Essays' || cat === activeFilter;
      const matchSearch = !search || title.includes(search);
      return matchFilter && matchSearch;
    });
  }

  function renderPosts() {
    let filtered = getPostsFiltered();

    // Sort
    const sortVal = sortSelect.value;
    if (sortVal === 'oldest') {
      filtered = filtered.sort((a, b) => (a.dataset.date || '').localeCompare(b.dataset.date || ''));
    } else if (sortVal === 'newest') {
      filtered = filtered.sort((a, b) => (b.dataset.date || '').localeCompare(a.dataset.date || ''));
    } else if (sortVal === 'longest') {
      filtered = filtered.sort((a, b) => {
        const aMin = parseInt((a.dataset.read || '0').replace(/\D.*/, ''), 10);
        const bMin = parseInt((b.dataset.read || '0').replace(/\D.*/, ''), 10);
        return bMin - aMin;
      });
    }

    // Hide all first
    postsData.forEach(p => p.style.display = 'none');

    // Show up to visibleCount
    const toShow = filtered.slice(0, visibleCount);
    toShow.forEach(p => p.style.display = 'block');

    // Results count
    resultsCount.textContent = `${toShow.length} of ${filtered.length} essays`;

    // Empty state
    emptyState.style.display = filtered.length === 0 ? 'block' : 'none';

    // Load more
    loadMoreWrap.style.display = filtered.length > visibleCount ? 'block' : 'none';
  }

  // Filter chips
  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      activeFilter = chip.dataset.filter || 'All Essays';
      visibleCount = INITIAL_VISIBLE;
      chips.forEach(c => {
        c.classList.remove('active');
        c.style.background = 'transparent';
        c.style.color = 'var(--muted2)';
        c.style.borderColor = 'var(--border2)';
      });
      chip.classList.add('active');
      chip.style.background = 'var(--accent-dim)';
      chip.style.color = 'var(--accent)';
      chip.style.borderColor = 'rgba(180,255,87,0.3)';
      renderPosts();
    });
  });

  // Sidebar category buttons
  sidebarCatBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.cat || 'All Essays';
      activeFilter = cat;
      visibleCount = INITIAL_VISIBLE;
      chips.forEach(c => {
        c.classList.remove('active');
        c.style.background = 'transparent';
        c.style.color = 'var(--muted2)';
        c.style.borderColor = 'var(--border2)';
        if (c.dataset.filter === cat) {
          c.classList.add('active');
          c.style.background = 'var(--accent-dim)';
          c.style.color = 'var(--accent)';
          c.style.borderColor = 'rgba(180,255,87,0.3)';
        }
      });
      renderPosts();
    });
    btn.addEventListener('mouseover', () => btn.style.color = 'var(--accent)');
    btn.addEventListener('mouseout', () => btn.style.color = 'var(--text2)');
  });

  // Search
  searchInput.addEventListener('input', () => { visibleCount = INITIAL_VISIBLE; renderPosts(); });

  // Sort
  sortSelect.addEventListener('change', renderPosts);

  // Reset
  resetBtn.addEventListener('click', () => {
    activeFilter = 'All Essays';
    visibleCount = INITIAL_VISIBLE;
    searchInput.value = '';
    sortSelect.value = 'newest';
    chips.forEach(c => {
      c.classList.remove('active');
      c.style.background = 'transparent';
      c.style.color = 'var(--muted2)';
      c.style.borderColor = 'var(--border2)';
    });
    const firstChip = chips[0];
    if (firstChip) {
      firstChip.classList.add('active');
      firstChip.style.background = 'var(--accent-dim)';
      firstChip.style.color = 'var(--accent)';
      firstChip.style.borderColor = 'rgba(180,255,87,0.3)';
    }
    renderPosts();
  });

  // Load more
  loadMoreBtn.addEventListener('click', () => {
    visibleCount += 4;
    renderPosts();
  });

  // Subscribe form
  const subscribeBtn = document.getElementById('subscribeBtn') as HTMLButtonElement;
  const subscribeEmail = document.getElementById('subscribeEmail') as HTMLInputElement;
  const subscribeFeedback = document.getElementById('subscribeFeedback') as HTMLElement;
  subscribeBtn.addEventListener('click', () => {
    const email = subscribeEmail.value.trim();
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      subscribeFeedback.textContent = 'Please enter a valid email.';
      subscribeFeedback.style.color = 'var(--accent3)';
      subscribeFeedback.style.display = 'block';
      return;
    }
    subscribeFeedback.textContent = '🎉 You\'re subscribed!';
    subscribeFeedback.style.color = 'var(--accent)';
    subscribeFeedback.style.display = 'block';
    subscribeEmail.value = '';
  });

  // Philosophy Ticker
  const quotes = [
    '"Technology without philosophy is just noise."',
    '"The unexamined system is not worth building."',
    '"Design is a moral act."',
    '"Complexity is a failure of explanation."',
    '"Every pixel is a decision. Every decision is a value."',
  ];
  let qIdx = 0;
  const ticker = document.getElementById('ticker') as HTMLElement;
  ticker.textContent = quotes[0];
  setInterval(() => {
    ticker.style.opacity = '0';
    setTimeout(() => {
      qIdx = (qIdx + 1) % quotes.length;
      ticker.textContent = quotes[qIdx];
      ticker.style.opacity = '1';
    }, 500);
  }, 4000);

  // Init active chip styles
  const firstChip = document.querySelector('.blog-chip.active') as HTMLElement;
  if (firstChip) {
    firstChip.style.background = 'var(--accent-dim)';
    firstChip.style.color = 'var(--accent)';
    firstChip.style.borderColor = 'rgba(180,255,87,0.3)';
  }

  // Init render
  renderPosts();
</script>

<style>
  @media (max-width: 768px) {
    .blog-main-grid { grid-template-columns: 1fr !important; }
    .blog-sidebar { position: static !important; }
    .micro-grid { grid-template-columns: 1fr !important; }
  }
  @media (max-width: 640px) {
    .blog-stats { gap: 24px !important; }
  }
</style>

