---
import Layout from '../layouts/Layout.astro';

const experience = [
  {
    period: '2024 - Present',
    role: 'Creative Technologist & AI Strategist',
    roleBn: 'ক্রিয়েটিভ টেকনোলজিস্ট',
    company: 'Freelance',
    desc: 'Building AI-native products, automation systems, and brand identities for clients in Bangladesh and globally.',
    skills: ['React', 'Astro', 'OpenAI', 'n8n', 'Figma', 'Brand Design'],
  },
  {
    period: '2024',
    role: 'Lead Designer & Developer',
    roleBn: 'লিড ডিজাইনার',
    company: 'Vabuuk Studio',
    desc: 'Led brand system and digital product for a philosophy-first AI startup, from concept to launch.',
    skills: ['Brand Identity', 'UX Design', 'Frontend', 'AI Integration'],
  },
  {
    period: '2023 - 2024',
    role: 'UI/UX Designer',
    roleBn: 'UI/UX ডিজাইনার',
    company: 'Various Clients',
    desc: 'Designed user-first interfaces for healthcare, education, and e-commerce products.',
    skills: ['Figma', 'User Research', 'Prototyping', 'Design Systems'],
  },
];

const education = [
  {
    period: '2021 - 2025',
    degree: 'Bachelor of Arts - Philosophy',
    degreeBn: 'বিএ - দর্শন',
    institution: 'Jahangirnagar University, Dhaka',
    desc: 'Focused on epistemology, ethics, and philosophy of mind with a technology and society lens.',
    highlights: ['Epistemology', 'Ethics & Logic', 'Digital Humanities', 'Critical Theory'],
    gpa: 'CGPA: 3.85/4.0',
  },
];

const certifications = [
  { name: 'UI/UX Design Professional', issuer: 'Google', year: '2024' },
  { name: 'AI Fundamentals', issuer: 'IBM', year: '2024' },
  { name: 'React Developer', issuer: 'Meta', year: '2023' },
  { name: 'Figma Advanced', issuer: 'Figma', year: '2023' },
];

const skills = [
  { name: 'UI/UX Design', level: 95 },
  { name: 'React / Astro', level: 87 },
  { name: 'Brand Strategy', level: 92 },
  { name: 'AI Automation', level: 82 },
  { name: 'TypeScript', level: 78 },
  { name: 'Design Systems', level: 90 },
];
---

<Layout title="Resume | Sazid Hossain" page="/resume">
  <section class="resume-hero">
    <div class="resume-orb resume-orb-a"></div>
    <div class="resume-orb resume-orb-b"></div>

    <div class="resume-wrap">
      <p class="section-label">Creative Profile</p>
      <h1 class="resume-title">
        <span class="gradient-text">Sazid Hossain</span>
        <br />
        Creative Technologist
      </h1>
      <p class="resume-subtitle">
        Philosophy-trained builder creating AI-native products, identity systems, and digital experiences with measurable impact.
      </p>
      <p class="resume-subtitle-bn">দর্শন, ডিজাইন এবং প্রযুক্তির সমন্বয়ে অর্থবহ ডিজিটাল কাজ তৈরি করি।</p>

      <div class="resume-actions">
        <button class="btn btn-primary" type="button" onclick="window.print()">Print Resume</button>
        <a class="btn btn-outline" href="/contact">Contact Me</a>
      </div>

      <div class="resume-stats">
        <article>
          <p>50+</p>
          <span>Projects</span>
        </article>
        <article>
          <p>3+ yrs</p>
          <span>Experience</span>
        </article>
        <article>
          <p>200+</p>
          <span>Clients</span>
        </article>
        <article>
          <p>24h</p>
          <span>Avg. Response</span>
        </article>
      </div>
    </div>
  </section>

  <section class="resume-content">
    <div class="resume-grid">
      <div>
        <section class="reveal">
          <h2 class="resume-heading"><span>01</span>Experience</h2>
          <div class="resume-stack">
            {experience.map((exp) => (
              <article class="card resume-card">
                <header>
                  <div>
                    <h3>{exp.role}</h3>
                    <p class="bn">{exp.roleBn}</p>
                  </div>
                  <div class="meta">
                    <p>{exp.period}</p>
                    <p>{exp.company}</p>
                  </div>
                </header>
                <p>{exp.desc}</p>
                <footer>
                  {exp.skills.map((s) => (
                    <span class="tag">{s}</span>
                  ))}
                </footer>
              </article>
            ))}
          </div>
        </section>

        <section class="reveal">
          <h2 class="resume-heading"><span>02</span>Education</h2>
          <div class="resume-stack">
            {education.map((edu) => (
              <article class="card resume-card">
                <header>
                  <div>
                    <h3>{edu.degree}</h3>
                    <p class="bn">{edu.degreeBn}</p>
                  </div>
                  <div class="meta">
                    <p>{edu.period}</p>
                    <p>{edu.institution}</p>
                  </div>
                </header>
                <p>{edu.desc}</p>
                <footer>
                  {edu.highlights.map((h) => (
                    <span class="tag">{h}</span>
                  ))}
                </footer>
                <p class="gpa">{edu.gpa}</p>
              </article>
            ))}
          </div>
        </section>
      </div>

      <aside class="resume-side reveal">
        <section class="card resume-panel">
          <h3>Skills</h3>
          <div class="meter-list">
            {skills.map((s) => (
              <article>
                <div>
                  <span>{s.name}</span>
                  <span>{s.level}%</span>
                </div>
                <div class="meter">
                  <i style={`width:${s.level}%`}></i>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="card resume-panel">
          <h3>Certifications</h3>
          <div class="cert-list">
            {certifications.map((c) => (
              <article>
                <div>
                  <p>{c.name}</p>
                  <span>{c.issuer}</span>
                </div>
                <b>{c.year}</b>
              </article>
            ))}
          </div>
        </section>

        <section class="card resume-panel">
          <h3>Languages</h3>
          <div class="lang-list">
            <article><span>Bengali</span><b>Native</b></article>
            <article><span>English</span><b>Fluent</b></article>
          </div>
        </section>
      </aside>
    </div>
  </section>
</Layout>

<style>
  .resume-hero {
    position: relative;
    overflow: clip;
    padding: clamp(96px, 11vw, 156px) clamp(20px, 5vw, 80px) clamp(70px, 10vw, 100px);
    border-bottom: 1px solid var(--border);
    background:
      radial-gradient(1200px 500px at 82% 0%, color-mix(in srgb, var(--accent) 12%, transparent), transparent 70%),
      radial-gradient(900px 500px at 20% 10%, color-mix(in srgb, var(--accent2) 16%, transparent), transparent 72%),
      linear-gradient(180deg, var(--bg2), var(--bg));
  }

  .resume-wrap {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
  }

  .resume-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(20px);
    pointer-events: none;
  }

  .resume-orb-a {
    width: clamp(200px, 24vw, 320px);
    height: clamp(200px, 24vw, 320px);
    top: -60px;
    right: -40px;
    background: color-mix(in srgb, var(--accent) 15%, transparent);
    animation: float 9s ease-in-out infinite;
  }

  .resume-orb-b {
    width: clamp(140px, 16vw, 220px);
    height: clamp(140px, 16vw, 220px);
    bottom: -50px;
    left: -30px;
    background: color-mix(in srgb, var(--accent2) 18%, transparent);
    animation: float 11s ease-in-out infinite reverse;
  }

  .resume-title {
    font-family: var(--font-display);
    font-size: clamp(2.3rem, 6vw, 4.8rem);
    line-height: 1.04;
    margin-bottom: 18px;
  }

  .resume-subtitle {
    max-width: 760px;
    font-size: var(--text-lg);
    color: var(--text2);
    line-height: 1.75;
    margin-bottom: 10px;
  }

  .resume-subtitle-bn {
    font-family: var(--font-bn);
    color: var(--muted);
    margin-bottom: 28px;
  }

  .resume-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 32px;
  }

  .resume-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 14px;
    max-width: 760px;
  }

  .resume-stats article {
    padding: 14px 14px 12px;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: color-mix(in srgb, var(--surface) 84%, transparent);
    backdrop-filter: blur(14px);
  }

  .resume-stats p {
    font-family: var(--font-display);
    color: var(--accent);
    font-size: var(--text-2xl);
    font-weight: 800;
    line-height: 1;
    margin-bottom: 6px;
  }

  .resume-stats span {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted2);
    font-family: var(--font-mono);
  }

  .resume-content {
    padding: clamp(52px, 7vw, 88px) clamp(20px, 5vw, 80px) clamp(90px, 11vw, 130px);
  }

  .resume-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1.7fr) minmax(280px, 1fr);
    gap: clamp(24px, 4vw, 52px);
    align-items: start;
  }

  .resume-heading {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
    font-family: var(--font-display);
    font-size: var(--text-2xl);
  }

  .resume-heading span {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  .resume-stack {
    display: grid;
    gap: 16px;
    margin-bottom: 34px;
  }

  .resume-card {
    padding: 24px;
    border-radius: 18px;
    backdrop-filter: blur(14px);
    background: color-mix(in srgb, var(--surface) 88%, transparent);
  }

  .resume-card header {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 10px;
  }

  .resume-card h3 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    line-height: 1.2;
    margin-bottom: 4px;
  }

  .resume-card .bn {
    font-family: var(--font-bn);
    font-size: var(--text-sm);
    color: var(--muted);
  }

  .resume-card .meta {
    text-align: right;
  }

  .resume-card .meta p:first-child {
    font-size: var(--text-xs);
    color: var(--accent);
    font-family: var(--font-mono);
  }

  .resume-card .meta p:last-child {
    font-size: var(--text-xs);
    color: var(--muted2);
  }

  .resume-card > p {
    color: var(--text2);
    margin-bottom: 14px;
  }

  .resume-card footer {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .resume-card .gpa {
    margin-top: 14px;
    border-top: 1px solid var(--border);
    padding-top: 10px;
    font-size: var(--text-xs);
    color: var(--accent);
    font-family: var(--font-mono);
  }

  .resume-side {
    position: sticky;
    top: 86px;
    display: grid;
    gap: 14px;
  }

  .resume-panel {
    padding: 20px;
    border-radius: 18px;
    backdrop-filter: blur(14px);
    background: color-mix(in srgb, var(--surface) 86%, transparent);
  }

  .resume-panel h3 {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    margin-bottom: 14px;
  }

  .meter-list {
    display: grid;
    gap: 12px;
  }

  .meter-list article > div:first-child {
    display: flex;
    justify-content: space-between;
    font-size: var(--text-sm);
    margin-bottom: 6px;
  }

  .meter-list article > div:first-child span:last-child {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .meter {
    height: 6px;
    border-radius: 999px;
    background: var(--surface2);
    overflow: hidden;
  }

  .meter i {
    display: block;
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
  }

  .cert-list,
  .lang-list {
    display: grid;
    gap: 10px;
  }

  .cert-list article,
  .lang-list article {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    align-items: flex-start;
    border-bottom: 1px solid var(--border);
    padding-bottom: 10px;
  }

  .cert-list article:last-child,
  .lang-list article:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .cert-list p {
    font-size: var(--text-sm);
    color: var(--text2);
    margin-bottom: 2px;
  }

  .cert-list span {
    font-size: var(--text-xs);
    color: var(--muted);
  }

  .cert-list b,
  .lang-list b {
    font-size: var(--text-xs);
    color: var(--accent);
    font-family: var(--font-mono);
    font-weight: 500;
  }

  .lang-list span {
    color: var(--text2);
    font-size: var(--text-sm);
  }

  @media (max-width: 900px) {
    .resume-grid {
      grid-template-columns: 1fr;
    }

    .resume-side {
      position: static;
    }
  }

  @media print {
    .resume-actions,
    .nav-fixed,
    footer {
      display: none !important;
    }

    .resume-hero,
    .resume-content {
      padding: 16px !important;
    }

    .resume-orb {
      display: none;
    }
  }
</style>
