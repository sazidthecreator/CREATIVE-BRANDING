---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.tsx';
import projectsData from '../../data/projects.json';

const categories = ['All', ...new Set(projectsData.map(p => p.category))];
const categoryCounts: Record<string, number> = { All: projectsData.length };
projectsData.forEach(p => {
  categoryCounts[p.category] = (categoryCounts[p.category] || 0) + 1;
});
const featuredProject = projectsData.find(p => p.featured);
const nonFeatured = projectsData.filter(p => !p.featured || p !== featuredProject);
---

<Layout title="Portfolio • Sazid Hossain — Creative Technologist" page="/portfolio">
  <!-- Hero -->
  <section class="portfolio-hero" style="
    padding: clamp(80px,12vw,140px) clamp(20px,5vw,80px) clamp(40px,6vw,64px);
    background: linear-gradient(180deg, var(--bg) 0%, var(--bg2) 100%);
    position: relative; overflow: clip;
  ">
    <div style="max-width:1200px;margin:0 auto;">
      <p class="section-label">
        <span class="inline-en">Selected Work</span>
        <span class="inline-bn" style="font-family:var(--font-bn)">নির্বাচিত কাজ</span>
      </p>
      <h1 style="font-family:var(--font-display);font-weight:800;font-size:var(--text-4xl);line-height:1.05;margin-bottom:20px;color:var(--text);">
        <span class="inline-en">Projects That <span class="gradient-text">Matter</span></span>
        <span class="inline-bn" style="font-family:var(--font-bn)">গুরুত্বপূর্ণ <span class="gradient-text">প্রজেক্ট</span></span>
      </h1>
      <p style="font-size:var(--text-lg);color:var(--text2);max-width:580px;line-height:1.8;margin-bottom:8px;">
        <span class="inline-en">From healthcare platforms to AI tools, here's a selection of work that combines design thinking with technical execution.</span>
        <span class="inline-bn" style="font-family:var(--font-bn)">স্বাস্থ্যসেবা থেকে এআই টুল — আমার নির্বাচিত কাজের সংকলন।</span>
      </p>

      <!-- Category Filter -->
      <div class="portfolio-filter" style="display:flex;gap:8px;flex-wrap:wrap;margin-top:40px;" id="filterBtns">
        {categories.map((cat, i) => (
          <button
            class={`filter-btn${i === 0 ? ' active' : ''}`}
            data-category={cat}
            style="
              padding: 8px 18px;border-radius:var(--radius-pill);cursor:pointer;
              font-size:9px;font-family:var(--font-mono);
              letter-spacing:0.12em;text-transform:uppercase;
              transition:all 0.25s var(--ease-spring);
              border:1px solid var(--border2);
              background:transparent;color:var(--muted2);
              backdrop-filter:blur(12px);
              display:inline-flex;align-items:center;gap:6px;
            "
          >
            {cat}
            <span style="
              display:inline-flex;align-items:center;justify-content:center;
              min-width:18px;height:18px;border-radius:var(--radius-pill);
              background:rgba(180,255,87,0.1);color:var(--accent);
              font-size:8px;padding:0 4px;
            ">
              {categoryCounts[cat] || 0}
            </span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Projects Grid -->
  <section class="portfolio-grid-wrap" style="padding: clamp(40px,6vw,64px) clamp(20px,5vw,80px) clamp(80px,12vw,140px);" id="projectsSection">
    <div style="max-width:1200px;margin:0 auto;">
      <!-- Count meta -->
      <div style="
        display:flex;justify-content:space-between;align-items:center;
        margin-bottom:32px;flex-wrap:wrap;gap:12px;
      ">
        <p id="projectCount" style="font-size:var(--text-xs);color:var(--muted2);font-family:var(--font-mono);letter-spacing:0.08em;">
          Showing {projectsData.length} of {projectsData.length} projects
        </p>
      </div>

      <!-- Featured hero card (if exists) -->
      {featuredProject && (
        <div class="project-item featured-hero reveal" data-category={featuredProject.category} style="margin-bottom:32px;animation:slideIn 0.6s var(--ease-expo) both">
          <a
            href={featuredProject.link || '#'}
            target={featuredProject.link && featuredProject.link !== '#' ? '_blank' : undefined}
            rel="noopener noreferrer"
            aria-label={`View featured project: ${featuredProject.title}`}
            style="display:block;text-decoration:none;color:inherit;"
          >
            <div class="card featured-card" style="position:relative;overflow:hidden;min-height:280px;display:flex;flex-direction:column;justify-content:flex-end;">
              <!-- Background emoji large -->
              <div style="
                position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
                font-size:clamp(120px,20vw,200px);opacity:0.08;pointer-events:none;
                filter:blur(2px);
              ">{featuredProject.emoji}</div>
              <!-- Gradient overlay -->
              <div style="
                position:absolute;inset:0;
                background:linear-gradient(135deg, rgba(180,255,87,0.06) 0%, transparent 60%, rgba(87,255,218,0.04) 100%);
                pointer-events:none;
              "></div>

              <div style="position:relative;z-index:1;padding:clamp(24px,4vw,40px);">
                <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;flex-wrap:wrap;">
                  <span style="
                    background:rgba(255,215,0,0.15);border:1px solid rgba(255,215,0,0.35);
                    border-radius:var(--radius-pill);padding:4px 12px;
                    font-size:9px;letter-spacing:0.1em;font-family:var(--font-mono);
                    text-transform:uppercase;color:var(--gold);
                  ">★ Featured Project</span>
                  <span class="tag">{featuredProject.category}</span>
                  <span style="font-size:9px;color:var(--muted2);font-family:var(--font-mono);">{featuredProject.year}</span>
                </div>
                <h2 style="font-family:var(--font-display);font-weight:800;font-size:var(--text-3xl);color:var(--text);margin-bottom:8px;line-height:1.2;">
                  {featuredProject.title}
                </h2>
                <p style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--accent);margin-bottom:12px;">{featuredProject.subtitle}</p>
                <p style="font-size:var(--text-base);color:var(--text2);max-width:600px;line-height:1.7;margin-bottom:24px;">{featuredProject.description}</p>
                <div style="display:flex;gap:12px;flex-wrap:wrap;">
                  <span class="btn-primary" style="font-size:9px;padding:10px 20px;">
                    <span class="inline-en">View Project →</span>
                    <span class="inline-bn" style="font-family:var(--font-bn)">প্রজেক্ট দেখুন →</span>
                  </span>
                </div>
              </div>
            </div>
          </a>
        </div>
      )}

      <!-- Projects grid -->
      <div class="portfolio-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:28px;" id="projectsGrid">
        {projectsData.map((project, i) => (
          <div class="project-item reveal" data-category={project.category} style={`animation-delay:${i*0.06}s`}>
            <ProjectCard project={project} index={i} client:visible />
          </div>
        ))}
      </div>

      <!-- Empty state -->
      <div id="emptyState" style="display:none;text-align:center;padding:80px 0;">
        <div style="font-size:48px;margin-bottom:16px;">🔍</div>
        <p style="font-size:var(--text-lg);color:var(--muted2);">
          <span class="inline-en">No projects in this category yet.</span>
          <span class="inline-bn" style="font-family:var(--font-bn)">এই বিভাগে এখনো প্রজেক্ট নেই।</span>
        </p>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="portfolio-process reveal" style="
    padding: clamp(80px,12vw,140px) clamp(20px,5vw,80px);
    background: var(--bg2);
    border-top: 1px solid rgba(180,255,87,0.06);
  ">
    <div style="max-width:1200px;margin:0 auto;">
      <p class="section-label">
        <span class="inline-en">How I Work</span>
        <span class="inline-bn" style="font-family:var(--font-bn)">আমার কর্মপ্রণালী</span>
      </p>
      <h2 style="font-family:var(--font-display);font-weight:800;font-size:var(--text-3xl);margin-bottom:clamp(40px,6vw,60px);color:var(--text);">
        My <span class="gradient-text">Process</span>
      </h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:24px;">
        {[
          { num: '01', title: 'Discover', titleBn: 'অনুসন্ধান', desc: 'Deep-dive into the problem space, users, and business context.' },
          { num: '02', title: 'Define', titleBn: 'নির্ধারণ', desc: 'Synthesize insights into clear design principles and constraints.' },
          { num: '03', title: 'Design', titleBn: 'ডিজাইন', desc: 'Rapid iteration from wireframes to high-fidelity prototypes.' },
          { num: '04', title: 'Develop', titleBn: 'ডেভেলপ', desc: 'Build with clean code, accessibility, and performance in mind.' },
          { num: '05', title: 'Deploy', titleBn: 'ডেপ্লয়', desc: 'Ship, measure, and iterate based on real user behavior.' },
        ].map((step, i) => (
          <div class="card reveal" style={`padding:28px;animation-delay:${i*0.08}s`}>
            <div style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--accent);margin-bottom:12px;letter-spacing:0.1em;">{step.num}</div>
            <h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-lg);color:var(--text);margin-bottom:4px;">
              <span class="inline-en">{step.title}</span>
              <span class="inline-bn" style="font-family:var(--font-bn)">{step.titleBn}</span>
            </h3>
            <p style="font-size:var(--text-sm);color:var(--text2);line-height:1.6;">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const projectItems = document.querySelectorAll('.project-item:not(.featured-hero)');
  const featuredHero = document.querySelector('.featured-hero') as HTMLElement | null;
  const emptyState = document.getElementById('emptyState');
  const countEl = document.getElementById('projectCount');
  const total = projectItems.length + (featuredHero ? 1 : 0);

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = (btn as HTMLElement).dataset.category;

      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      let visible = 0;

      // Featured hero visibility
      if (featuredHero) {
        const featCat = featuredHero.dataset.category;
        const show = cat === 'All' || featCat === cat;
        featuredHero.style.display = show ? 'block' : 'none';
        if (show) visible++;
      }

      // Regular items
      projectItems.forEach(item => {
        const el = item as HTMLElement;
        const show = cat === 'All' || el.dataset.category === cat;
        el.style.display = show ? 'block' : 'none';
        if (show) visible++;
      });

      if (emptyState) emptyState.style.display = visible === 0 ? 'block' : 'none';
      if (countEl) countEl.textContent = `Showing ${visible} of ${total} projects`;
    });
  });
</script>

<style>
  .filter-btn.active {
    background: var(--accent-dim) !important;
    color: var(--accent) !important;
    border-color: rgba(180,255,87,0.4) !important;
    box-shadow: 0 4px 16px rgba(180,255,87,0.15) !important;
    transform: translateY(-1px);
  }
  .filter-btn.active span {
    background: rgba(180,255,87,0.2) !important;
  }
  .portfolio-grid { align-items: stretch; }
  .project-item { height: 100%; }
  .featured-card { border-color: rgba(180,255,87,0.2); }
  .featured-card:hover { border-color: rgba(180,255,87,0.4) !important; }

  @media (max-width: 640px) {
    .portfolio-grid { grid-template-columns: 1fr !important; gap: 18px !important; }
  }
  @media (max-width: 375px) {
    .portfolio-hero, .portfolio-grid-wrap, .portfolio-process {
      padding-left: 16px !important;
      padding-right: 16px !important;
    }
    .filter-btn { padding: 6px 12px !important; }
  }
  @media (min-width: 1440px) {
    .portfolio-grid { grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)) !important; gap: 32px !important; }
  }
</style>
