---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.tsx';
import projectsData from '../../data/projects.json';

const categories = ['All', ...new Set(projectsData.map(p => p.category))];
---

<Layout title="Portfolio • Sazid Hossain — Creative Technologist" page="/portfolio">
  <!-- Hero -->
  <section class="portfolio-hero" style="
    padding: clamp(80px,12vw,140px) clamp(20px,5vw,80px);
    background: linear-gradient(180deg, var(--bg) 0%, var(--bg2) 100%);
  ">
    <div style="max-width:1200px;margin:0 auto;">
      <p class="section-label">Selected Work</p>
      <h1 style="
        font-family:var(--font-display);font-weight:800;
        font-size:var(--text-4xl);line-height:1.05;
        margin-bottom:20px;color:var(--text);
      ">
        Projects That <span class="gradient-text">Matter</span>
      </h1>
      <p style="font-size:var(--text-lg);color:var(--text2);max-width:580px;line-height:1.8;margin-bottom:8px;">
        From healthcare platforms to AI tools, here's a selection of work that combines design thinking
        with technical execution.
      </p>
      <p style="font-family:var(--font-bn);font-size:var(--text-base);color:var(--muted);margin-bottom:48px;">
        স্বাস্থ্যসেবা থেকে এআই টুল — আমার নির্বাচিত কাজের সংকলন।
      </p>

      <!-- Category Filter -->
      <div class="portfolio-filter" style="display:flex;gap:8px;flex-wrap:wrap;" id="filterBtns">
        {categories.map((cat, i) => (
          <button
            class={`filter-btn${i === 0 ? ' active' : ''}`}
            data-category={cat}
            style="
              padding: 8px 20px;border-radius:99px;cursor:pointer;
              font-size:var(--text-xs);font-family:var(--font-mono);
              letter-spacing:0.1em;text-transform:uppercase;
              transition:all 0.2s;border:1px solid var(--border2);
              background:transparent;color:var(--muted2);
            "
          >
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Projects Grid -->
  <section class="portfolio-grid-wrap" style="padding: clamp(40px,8vw,80px) clamp(20px,5vw,80px) clamp(80px,12vw,140px);" id="projectsSection">
    <div style="max-width:1200px;margin:0 auto;">
      <div class="portfolio-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:28px;" id="projectsGrid">
        {projectsData.map((project, i) => (
          <div class="project-item" data-category={project.category} style={`animation:slideIn 0.6s cubic-bezier(0.16,1,0.3,1) ${i*0.08}s both`}>
            <ProjectCard project={project} index={i} client:visible />
          </div>
        ))}
      </div>

      <!-- Empty state -->
      <div id="emptyState" style="display:none;text-align:center;padding:80px 0;">
        <div style="font-size:48px;margin-bottom:16px;">🔍</div>
        <p style="font-size:var(--text-lg);color:var(--muted2);">No projects in this category yet.</p>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="portfolio-process" style="
    padding: clamp(80px,12vw,140px) clamp(20px,5vw,80px);
    background: var(--bg2);
    border-top: 1px solid var(--border);
  " class="reveal">
    <div style="max-width:1200px;margin:0 auto;">
      <p class="section-label">How I Work</p>
      <h2 style="font-family:var(--font-display);font-weight:800;font-size:var(--text-3xl);margin-bottom:clamp(40px,6vw,60px);color:var(--text);">
        My <span class="gradient-text">Process</span>
      </h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:24px;">
        {[
          { num: '01', title: 'Discover', desc: 'Deep-dive into the problem space, users, and business context.' },
          { num: '02', title: 'Define', desc: 'Synthesize insights into clear design principles and constraints.' },
          { num: '03', title: 'Design', desc: 'Rapid iteration from wireframes to high-fidelity prototypes.' },
          { num: '04', title: 'Develop', desc: 'Build with clean code, accessibility, and performance in mind.' },
          { num: '05', title: 'Deploy', desc: 'Ship, measure, and iterate based on real user behavior.' },
        ].map(step => (
          <div class="card" style="padding:28px;">
            <div style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--accent);margin-bottom:12px;">{step.num}</div>
            <h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-lg);color:var(--text);margin-bottom:8px;">{step.title}</h3>
            <p style="font-size:var(--text-sm);color:var(--text2);line-height:1.6;">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  // Category filtering
  const filterBtns = document.querySelectorAll('.filter-btn');
  const projectItems = document.querySelectorAll('.project-item');
  const emptyState = document.getElementById('emptyState');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = (btn as HTMLElement).dataset.category;

      filterBtns.forEach(b => {
        b.classList.remove('active');
      });
      btn.classList.add('active');

      let visible = 0;
      projectItems.forEach(item => {
        const el = item as HTMLElement;
        if (cat === 'All' || el.dataset.category === cat) {
          el.style.display = 'block';
          visible++;
        } else {
          el.style.display = 'none';
        }
      });

      if (emptyState) emptyState.style.display = visible === 0 ? 'block' : 'none';
    });
  });

  // Init active style
</script>

<style>
  .portfolio-hero,
  .portfolio-process {
    position: relative;
    overflow: clip;
  }

  .portfolio-hero::before,
  .portfolio-process::before {
    content: '';
    position: absolute;
    width: min(420px, 52vw);
    aspect-ratio: 1;
    border-radius: 50%;
    filter: blur(26px);
    pointer-events: none;
    background: color-mix(in srgb, var(--accent2) 12%, transparent);
    right: -120px;
    top: -140px;
  }

  .portfolio-filter {
    align-items: center;
    row-gap: 10px;
  }

  .filter-btn {
    backdrop-filter: blur(12px);
  }

  .filter-btn.active {
    background: var(--accent-dim) !important;
    color: var(--accent) !important;
    border-color: color-mix(in srgb, var(--accent) 40%, var(--border2)) !important;
    box-shadow: 0 8px 20px color-mix(in srgb, var(--accent) 22%, transparent);
  }

  .portfolio-grid {
    align-items: stretch;
  }

  .project-item {
    height: 100%;
  }

  .portfolio-grid-wrap {
    background: linear-gradient(180deg, transparent, color-mix(in srgb, var(--surface) 18%, transparent));
  }

  @media (max-width: 640px) {
    .portfolio-grid {
      grid-template-columns: 1fr !important;
      gap: 18px !important;
    }
  }
</style>
